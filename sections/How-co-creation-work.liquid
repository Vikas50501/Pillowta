    },
    {
      "type": "color",
      "id": "cta_bg_hover",
      "label": "Button background (hover)",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "cta_text_hover",
      "label": "Button text (hover)",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "cta_border_hover",
      "label": "Button border (hover)",
