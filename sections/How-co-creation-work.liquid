      "type": "range",
      "id": "cta_radius",
      "label": "Button corner radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 5
    }
  ],

  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 12,
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Step number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Eyebrow label (small uppercase)",
          "default": "Your Voice"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Tell Us What You Actually Want"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Fill a short survey about your desires, needs, and what's missing. No right answers. Just real ones. Takes under 10 minutes.</p>"
        },
        {
          "type": "checkbox",
          "id": "highlight",
          "label": "Make this step dark (highlighted)",
          "default": false
        }
      ]
    }
  ],

  "presets": [
    {
      "name": "How It Works",
      "category": "Text",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "01",
            "label": "Your Voice",
            "title": "Tell Us What You Actually Want",
            "description": "<p>Fill a short survey about your desires, needs, and what's missing. No right answers. Just real ones. Takes under 10 minutes.</p>",
            "highlight": false
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "02",
            "label": "You Shape It",
            "title": "Your Answers Influence the Product",
            "description": "<p>We read every response. The patterns you reveal — scents, textures, rituals, gaps — directly inform what we create next.</p>",
            "highlight": false
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "03",
