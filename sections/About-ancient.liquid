    },
    {
      "type": "color",
      "id": "strip_bg",
      "label": "Strip Background Color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "strip_border_color",
      "label": "Strip Border Color",
      "default": "rgba(255,255,255,0.10)"
    },
    {
