{%- comment -%}
  ============================================================
  SECTION: Intro Strip — Theme-Matched Build
  ------------------------------------------------------------
  Fonts     : Aleo (heading + body), SF Mono (button)
  Colors    : Matched to theme token system
  Button    : Button 4 (lime-green) default; fully configurable
  Fixes     : Missing <a tag, button border-width, line-height,
              heading weight, font stack, default color values
  ============================================================
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign section_id = 'intro-strip-' | append: section.id
-%}

<section
  id="{{ section_id }}"
  class="intro-strip intro-strip--img-{{ s.image_position }} intro-strip--align-{{ s.content_alignment }}"
  style="
    --is-bg: {{ s.bg_color }};
    --is-heading-color: {{ s.heading_color }};
    --is-accent: {{ s.accent_color }};
    --is-text: {{ s.text_color }};
    --is-heading-font: {{ s.heading_font_family }};
    --is-body-font: {{ s.body_font_family }};
    --is-btn-font: {{ s.button_font_family }};
    --is-pad-top: {{ s.padding_top }}px;
    --is-pad-bottom: {{ s.padding_bottom }}px;
    --is-pad-top-mobile: {{ s.padding_top_mobile }}px;
    --is-pad-bottom-mobile: {{ s.padding_bottom_mobile }}px;
    --is-side-pad: {{ s.side_padding }}vw;
    --is-gap: {{ s.column_gap }}px;
    --is-max-width: {{ s.container_max_width }}px;
    --is-heading-size: {{ s.heading_size }}px;
    --is-heading-size-mobile: {{ s.heading_size_mobile }}px;
    --is-body-size: {{ s.body_size }}px;
    --is-image-ratio: {{ s.image_ratio }};
    --is-image-radius: {{ s.image_radius }}px;
    --is-heading-desc-gap: {{ s.heading_desc_gap }}px;
    --is-col-ratio: {{ s.column_ratio }};
  "
>
  <div class="intro-strip__inner">

    {%- comment -%} ── IMAGE COLUMN ── {%- endcomment -%}
    <div class="intro-strip__media">
      <div class="intro-strip__image-wrap">
        {%- if s.image != blank -%}
          {%- assign img_alt = s.image.alt | default: s.heading | default: 'Image' | strip_html -%}
          <img
            src="{{ s.image | image_url: width: 1600 }}"
            srcset="{{ s.image | image_url: width: 400 }} 400w,
                    {{ s.image | image_url: width: 600 }} 600w,
                    {{ s.image | image_url: width: 800 }} 800w,
                    {{ s.image | image_url: width: 1000 }} 1000w,
                    {{ s.image | image_url: width: 1200 }} 1200w,
                    {{ s.image | image_url: width: 1600 }} 1600w"
            sizes="(max-width: 900px) 100vw, 50vw"
            alt="{{ img_alt | escape }}"
            width="{{ s.image.width }}"
            height="{{ s.image.height }}"
            loading="lazy"
            class="intro-strip__image"
          />
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'intro-strip__image intro-strip__image--placeholder' }}
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ── CONTENT COLUMN ── {%- endcomment -%}
    <div class="intro-strip__content">

      {%- if s.eyebrow != blank -%}
        <p class="intro-strip__eyebrow">{{ s.eyebrow }}</p>
      {%- endif -%}

      {%- if s.heading != blank -%}
        <{{ s.heading_tag }} class="intro-strip__heading">
          {{ s.heading }}
        </{{ s.heading_tag }}>
      {%- endif -%}

      {%- if s.description != blank -%}
        <div class="intro-strip__description rte">
          {{ s.description }}
        </div>
      {%- endif -%}

      {%- if s.button_label != blank -%}
        {%- if s.button_opens_modal -%}
          <button
            type="button"
            class="intro-strip__btn"
            onclick="var m=document.querySelector('.coc-modal'); if(m){m.hidden=false;m.classList.add('is-open');document.body.style.overflow='hidden';}"
          >
            {{ s.button_label }}
          </button>
        {%- else -%}
          <a
            href="{{ s.button_link | default: '#' }}"
            class="intro-strip__btn"
            {% if s.button_open_new_tab %}target="_blank" rel="noopener"{% endif %}
          >
            {{ s.button_label }}
          </a>
        {%- endif -%}
      {%- endif -%}

    </div>

  </div>
</section>

<style>
  /* ── Section shell ─────────────────────────────────────── */
  #{{ section_id }}.intro-strip {
    background: var(--is-bg);
    padding: var(--is-pad-top) var(--is-side-pad) var(--is-pad-bottom);
    font-family: var(--is-body-font);
    font-weight: 300;
  }

  #{{ section_id }} .intro-strip__inner {
    display: grid;
    grid-template-columns: var(--is-col-ratio);
    gap: var(--is-gap);
    align-items: center;
    max-width: var(--is-max-width);
    margin: 0 auto;
  }

  /* Image position swap */
  #{{ section_id }}.intro-strip--img-right .intro-strip__media   { order: 2; }
  #{{ section_id }}.intro-strip--img-right .intro-strip__content { order: 1; }

  /* ── Image ─────────────────────────────────────────────── */
  #{{ section_id }} .intro-strip__media {
    width: 100%;
    position: relative;
  }

  #{{ section_id }} .intro-strip__image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: var(--is-image-ratio);
    border-radius: var(--is-image-radius);
    overflow: hidden;
    background: #F5F5F5; /* theme table header / placeholder tone */
    min-height: 200px;
  }

  @supports not (aspect-ratio: 1) {
    #{{ section_id }} .intro-strip__image-wrap {
      min-height: 400px;
    }
  }

  #{{ section_id }} .intro-strip__image {
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    display: block !important;
    max-width: none !important;
    max-height: none !important;
  }

  #{{ section_id }} .intro-strip__image--placeholder {
    background: #F5F5F5;
  }

  /* ── Content ───────────────────────────────────────────── */
  #{{ section_id }}.intro-strip--align-left   .intro-strip__content { text-align: left;   align-items: flex-start; }
  #{{ section_id }}.intro-strip--align-center .intro-strip__content { text-align: center; align-items: center; }
  #{{ section_id }}.intro-strip--align-right  .intro-strip__content { text-align: right;  align-items: flex-end; }

  #{{ section_id }} .intro-strip__content {
    display: flex;
    flex-direction: column;
    gap: var(--is-heading-desc-gap);
  }

  /* Eyebrow — matches theme breadcrumb / label style */
  #{{ section_id }} .intro-strip__eyebrow {
    font-family: var(--is-body-font);
    font-size: 12px;             /* theme breadcrumb font-size: 12 */
    letter-spacing: 0.2em;       /* theme body letter-spacing: 2 */
    text-transform: uppercase;   /* theme: Text Uppercase */
    color: var(--is-accent);
    margin: 0;
    font-weight: 400;
  }

  /* Heading — Aleo, Medium weight, theme heading values */
  #{{ section_id }} .intro-strip__heading {
    font-family: var(--is-heading-font);
    font-size: var(--is-heading-size);
    font-weight: 500;            /* theme: Medium */
    line-height: 1.3;            /* theme heading line-height */
    letter-spacing: 0.001em;     /* theme heading letter-spacing: 1 */
    color: var(--is-heading-color);
    margin: 0;
  }

  #{{ section_id }} .intro-strip__heading em,
  #{{ section_id }} .intro-strip__heading i {
    font-style: italic;
    color: var(--is-accent);
  }

  /* Description — Aleo, theme body values */
  #{{ section_id }} .intro-strip__description {
    font-family: var(--is-body-font);
    font-size: var(--is-body-size);
    line-height: 1.6;            /* theme body line-height */
    letter-spacing: 0.002em;     /* theme body letter-spacing: 2 */
    color: var(--is-text);
    max-width: 560px;
    font-weight: 300;
    margin: 0;
  }

  #{{ section_id }}.intro-strip--align-center .intro-strip__description { margin-left: auto; margin-right: auto; }
  #{{ section_id }}.intro-strip--align-right  .intro-strip__description { margin-left: auto; }

  #{{ section_id }} .intro-strip__description p { margin: 0 0 14px; }
  #{{ section_id }} .intro-strip__description p:last-child { margin-bottom: 0; }

  #{{ section_id }} .intro-strip__description a {
    color: var(--is-accent);
    text-decoration: underline;
  }

  /* ── Button — Button 4 default (lime-green) ────────────── */
  #{{ section_id }} .intro-strip__btn,
  #{{ section_id }} button.intro-strip__btn {
    display: inline-block;
    width: fit-content;
    font-family: var(--is-btn-font);   /* theme: SF Mono */
    font-size: 12px;                   /* theme button font-size: 12 */
    font-weight: 700;                  /* theme: Bold */
    letter-spacing: 0.12em;
    text-transform: uppercase;         /* theme: Uppercase */
    padding: 14px 32px;
    text-decoration: none;
    background: {{ s.button_bg }};
    color: {{ s.button_text_color }};
    border: 2px solid {{ s.button_border }};  /* theme border-width: 2 */
    border-radius: {{ s.button_radius }}px;   /* theme: 5px */
    transition: background 0.22s ease, color 0.22s ease, border-color 0.22s ease;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    margin-top: 8px;
  }

  #{{ section_id }} .intro-strip__btn:hover,
  #{{ section_id }} button.intro-strip__btn:hover {
    background: {{ s.button_bg_hover }};
    color: {{ s.button_text_hover }};
    border-color: {{ s.button_border_hover }};
  }

  /* ── Responsive ────────────────────────────────────────── */
  @media (max-width: 900px) {
    #{{ section_id }}.intro-strip {
      padding: var(--is-pad-top-mobile) 6vw var(--is-pad-bottom-mobile);
    }

    #{{ section_id }} .intro-strip__inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    #{{ section_id }} .intro-strip__media  { order: {% if s.mobile_image_first %}1{% else %}2{% endif %}; }
    #{{ section_id }} .intro-strip__content { order: {% if s.mobile_image_first %}2{% else %}1{% endif %}; }

    /* Override image-right swap on mobile — stacking always resets */
    #{{ section_id }}.intro-strip--img-right .intro-strip__media  { order: {% if s.mobile_image_first %}1{% else %}2{% endif %}; }
    #{{ section_id }}.intro-strip--img-right .intro-strip__content { order: {% if s.mobile_image_first %}2{% else %}1{% endif %}; }

    #{{ section_id }} .intro-strip__heading {
      font-size: var(--is-heading-size-mobile);
    }

    #{{ section_id }} .intro-strip__content {
      text-align: left !important;
      align-items: flex-start !important;
    }
  }
</style>

{% schema %}
{
  "name": "Intro Strip",
  "tag": "section",
  "class": "section-intro-strip",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left",  "label": "Image on LEFT – Text on RIGHT" },
        { "value": "right", "label": "Image on RIGHT – Text on LEFT" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "column_ratio",
      "label": "Column width ratio",
      "options": [
        { "value": "1fr 1fr", "label": "50 / 50 (equal)" },
        { "value": "2fr 3fr", "label": "40 / 60" },
        { "value": "3fr 2fr", "label": "60 / 40" },
        { "value": "1fr 2fr", "label": "33 / 67" },
        { "value": "2fr 1fr", "label": "67 / 33" }
      ],
      "default": "1fr 1fr",
      "info": "First value = image column, second = text column."
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "checkbox",
      "id": "mobile_image_first",
      "label": "Show image first on mobile",
      "default": false
    },
    {
      "type": "range",
      "id": "container_max_width",
      "label": "Max content width",
      "min": 1000,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1440
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side padding",
      "min": 2,
      "max": 12,
      "step": 1,
      "unit": "vw",
      "default": 7
    },
    {
      "type": "range",
      "id": "column_gap",
      "label": "Gap between columns",
      "min": 20,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "heading_desc_gap",
      "label": "Gap between heading and description",
      "min": 8,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 56
    },

    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image aspect ratio",
      "options": [
        { "value": "1 / 1",  "label": "Square (1:1)" },
        { "value": "4 / 5",  "label": "Portrait (4:5)" },
        { "value": "3 / 4",  "label": "Portrait (3:4)" },
        { "value": "2 / 3",  "label": "Tall (2:3)" },
        { "value": "5 / 4",  "label": "Landscape (5:4)" },
        { "value": "4 / 3",  "label": "Landscape (4:3)" },
        { "value": "3 / 2",  "label": "Landscape (3:2)" },
        { "value": "16 / 9", "label": "Widescreen (16:9)" }
      ],
      "default": "4 / 5"
    },
    {
      "type": "range",
      "id": "image_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 5
    },

    {
      "type": "header",
      "content": "Text Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (small label above heading, optional)"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Wrap words in <em> tags for italic accent color.",
      "default": "<p>This isn't a waitlist. <em>It's a workshop.</em></p>"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Most brands build in silence, then ask for reviews. We do it differently. You tell us what's missing, what you actually want, and what nobody is making yet. We build it. You get it first — at 20% off, because you helped make it.</p>"
    },

    {
      "type": "header",
      "content": "Button (optional)"
    },
    {
      "type": "checkbox",
      "id": "button_opens_modal",
      "label": "Button opens survey form (modal)",
      "default": false,
      "info": "When enabled, triggers the co-creation survey popup instead of a link."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "info": "Leave blank to hide the button."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link",
      "info": "Ignored when 'opens modal' is enabled."
    },
    {
      "type": "checkbox",
      "id": "button_open_new_tab",
      "label": "Open button in new tab",
      "default": false
    },
    {
      "type": "color",
      "id": "button_bg",
      "label": "Button background (Button 4 default)",
      "default": "#e63946"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_border",
      "label": "Button border color",
      "default": "#e63946"
    },
    {
      "type": "color",
      "id": "button_bg_hover",
      "label": "Button background (hover)",
      "default": "#d32f3f"
    },
    {
      "type": "color",
      "id": "button_text_hover",
      "label": "Button text (hover)",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_border_hover",
      "label": "Button border (hover)",
      "default": "#d32f3f"
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button corner radius",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 5
    },

    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#0d0d0d"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description text color",
      "default": "#b0b0b0"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Italic accent / eyebrow color",
      "default": "#e63946"
    },

    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "text",
      "id": "heading_font_family",
      "label": "Heading font-family (CSS)",
      "default": "'Aleo', serif"
    },
    {
      "type": "text",
      "id": "body_font_family",
      "label": "Body font-family (CSS)",
      "default": "'Aleo', serif"
    },
    {
      "type": "text",
      "id": "button_font_family",
      "label": "Button font-family (CSS)",
      "info": "Theme uses SF Mono for buttons. System font — no import needed.",
      "default": "'SF Mono', 'Fira Code', 'Fira Mono', monospace"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size (desktop)",
      "min": 28,
      "max": 100,
      "step": 2,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading size (mobile)",
      "min": 22,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Description text size",
      "min": 13,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 14
    }
  ],
  "presets": [
    {
      "name": "Intro Strip",
      "category": "Text",
      "settings": {
        "image_position": "left",
        "content_alignment": "left"
      }
    }
  ]
}
{% endschema %}
