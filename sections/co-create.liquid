    },
    {
      "type": "text",
      "id": "stat_secondary",
      "label": "Secondary stat text",
      "default": "Product 2 is in the making. Your answers shape it."
    },
    {
      "type": "color",
      "id": "stat_secondary_color",
      "label": "Secondary stat color",
      "default": "#b0b0b0"
    },
    {
      "type": "range",
      "id": "stat_margin_top",
      "label": "Stats top spacing",
      "min": 16,
      "max": 96,
      "step": 4,
      "unit": "px",
      "default": 48
    },

    {
      "type": "header",
      "content": "🔘 Buttons"
    },
    {
      "type": "text",
      "id": "btn_primary_text_label",
      "label": "Primary button text",
      "info": "Leave empty to hide."
    },
    {
      "type": "color",
      "id": "btn_primary_bg",
      "label": "Primary bg (Button 4 default)",
      "default": "#e63946"
    },
    {
      "type": "color",
      "id": "btn_primary_text",
      "label": "Primary text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_primary_border",
      "label": "Primary border color",
      "default": "#e63946"
    },
    {
      "type": "color",
      "id": "btn_primary_hover_bg",
      "label": "Primary hover bg",
      "default": "#d32f3f"
    },
    {
      "type": "color",
      "id": "btn_primary_hover_text",
      "label": "Primary hover text",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_primary_hover_border",
      "label": "Primary hover border",
      "default": "#d32f3f"
    },
    {
      "type": "text",
      "id": "btn_secondary_text_label",
      "label": "Secondary button text",
      "info": "Leave empty to hide."
    },
    {
      "type": "url",
      "id": "btn_secondary_link",
      "label": "Secondary button link"
    },
    {
      "type": "color",
      "id": "btn_secondary_text",
      "label": "Secondary text color (Button 3 default)",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_secondary_border",
      "label": "Secondary border color",
      "default": "#ffffff66"
    },
    {
      "type": "color",
      "id": "btn_secondary_hover_bg",
      "label": "Secondary hover bg",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "btn_secondary_hover_text",
      "label": "Secondary hover text",
      "default": "#0d0d0d"
    },
    {
      "type": "color",
      "id": "btn_secondary_hover_border",
      "label": "Secondary hover border",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "button_radius",
      "label": "Button corner radius",
      "min": 0,
      "max": 40,
