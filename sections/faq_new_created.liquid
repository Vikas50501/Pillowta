{%- comment -%}
  ============================================================
  SECTION: FAQ Accordion
  ------------------------------------------------------------
  Heading sits top-RIGHT.
  Full-width accordion rows below — each row:
    • Question (left) + toggle icon (right)
    • Answer expands on click (no page reload)
  Each FAQ is a block — add, remove, reorder freely.
  Pure CSS + vanilla JS, no dependencies.
  ============================================================
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign section_id = 'faq-' | append: section.id
-%}

<section
  id="{{ section_id }}"
  class="faq"
  style="
    --faq-bg: {{ s.bg_color }};
    --faq-heading: {{ s.heading_color }};
    --faq-accent: {{ s.accent_color }};
    --faq-q-color: {{ s.question_color }};
    --faq-a-color: {{ s.answer_color }};
    --faq-border: {{ s.border_color }};
    --faq-icon: {{ s.icon_color }};
    --faq-heading-font: {{ s.heading_font_family }};
    --faq-body-font: {{ s.body_font_family }};
    --faq-heading-size: {{ s.heading_size }}px;
    --faq-heading-size-mobile: {{ s.heading_size_mobile }}px;
    --faq-q-size: {{ s.question_size }}px;
    --faq-a-size: {{ s.answer_size }}px;
    --faq-icon-size: {{ s.icon_size }}px;
    --faq-row-pad-y: {{ s.row_padding_y }}px;
    --faq-answer-pad-bottom: {{ s.answer_padding_bottom }}px;
    --faq-pad-top: {{ s.padding_top }}px;
    --faq-pad-bottom: {{ s.padding_bottom }}px;
    --faq-pad-top-mobile: {{ s.padding_top_mobile }}px;
    --faq-pad-bottom-mobile: {{ s.padding_bottom_mobile }}px;
    --faq-side-pad: {{ s.side_padding }}vw;
    --faq-max-width: {{ s.container_max_width }}px;
    --faq-heading-gap: {{ s.heading_gap }}px;
    --faq-answer-max-width: {{ s.answer_max_width }}px;
  "
>
  <div class="faq__inner">

    {%- comment -%} ── HEADING (right-aligned) ── {%- endcomment -%}
    {%- if s.heading != blank -%}
      <div class="faq__heading-wrap">
        <{{ s.heading_tag }} class="faq__heading">
          {{ s.heading }}
        </{{ s.heading_tag }}>
      </div>
    {%- endif -%}

    {%- comment -%} ── ACCORDION ── {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="faq__list" role="list">
        {%- for block in section.blocks -%}
          {%- assign b = block.settings -%}
          {%- assign item_id = section_id | append: '-item-' | append: forloop.index -%}

          <div
            class="faq__item{% if forloop.first and s.first_open %} faq__item--open{% endif %}"
            role="listitem"
            {{ block.shopify_attributes }}
          >
            <button
              class="faq__question"
              aria-expanded="{% if forloop.first and s.first_open %}true{% else %}false{% endif %}"
              aria-controls="{{ item_id }}"
              type="button"
            >
              <span class="faq__question-text">{{ b.question }}</span>
              <span class="faq__icon" aria-hidden="true">
                {%- if s.icon_style == 'plus' -%}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <line class="faq__icon-h" x1="0" y1="8" x2="16" y2="8" stroke="currentColor" stroke-width="1.5"/>
                    <line class="faq__icon-v" x1="8" y1="0" x2="8" y2="16" stroke="currentColor" stroke-width="1.5"/>
                  </svg>
                {%- elsif s.icon_style == 'x' -%}
                  <span class="faq__icon-x">×</span>
                {%- else -%}
                  <svg width="16" height="10" viewBox="0 0 16 10" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path class="faq__icon-chevron" d="M1 1L8 8L15 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                  </svg>
                {%- endif -%}
              </span>
            </button>

            <div
              class="faq__answer-wrap"
              id="{{ item_id }}"
              role="region"
            >
              <div class="faq__answer rte">
                {{ b.answer }}
              </div>
            </div>
          </div>

        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  #{{ section_id }}.faq {
    background: var(--faq-bg);
    padding: var(--faq-pad-top) var(--faq-side-pad) var(--faq-pad-bottom);
    font-family: var(--faq-body-font);
    font-weight: 300;
  }

  #{{ section_id }} .faq__inner {
    max-width: var(--faq-max-width);
    margin: 0 auto;
  }

  /* ── HEADING (right aligned) ── */
  #{{ section_id }} .faq__heading-wrap {
    text-align: right;
    margin-bottom: var(--faq-heading-gap);
  }
  #{{ section_id }} .faq__heading {
    font-family: var(--faq-heading-font);
    font-size: var(--faq-heading-size);
    font-weight: 300;
    line-height: 1.1;
    color: var(--faq-heading);
    margin: 0;
    letter-spacing: -0.01em;
    display: inline;
  }
  #{{ section_id }} .faq__heading em,
  #{{ section_id }} .faq__heading i {
    font-style: italic;
    color: var(--faq-accent);
  }

  /* ── LIST ── */
  #{{ section_id }} .faq__list {
    border-top: 1px solid var(--faq-border);
  }

  /* ── ITEM ── */
  #{{ section_id }} .faq__item {
    border-bottom: 1px solid var(--faq-border);
  }

  /* ── QUESTION BUTTON ── */
  #{{ section_id }} .faq__question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 24px;
    width: 100%;
    padding: var(--faq-row-pad-y) 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--faq-heading-font);
    font-size: var(--faq-q-size);
    font-weight: 400;
    color: var(--faq-q-color);
    line-height: 1.3;
    -webkit-appearance: none;
    appearance: none;
  }
  #{{ section_id }} .faq__question:focus-visible {
    outline: 2px solid var(--faq-accent);
    outline-offset: 2px;
    border-radius: 2px;
  }

  #{{ section_id }} .faq__question-text {
    flex: 1;
  }

  /* ── ICON ── */
  #{{ section_id }} .faq__icon {
    flex-shrink: 0;
    width: var(--faq-icon-size);
    height: var(--faq-icon-size);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--faq-icon);
    transition: transform 0.3s ease;
  }
  #{{ section_id }} .faq__icon svg {
    display: block;
    overflow: visible;
  }
  #{{ section_id }} .faq__icon-x {
    font-size: calc(var(--faq-icon-size) * 1.2);
    line-height: 1;
    font-weight: 300;
    font-family: var(--faq-body-font);
  }

  /* Plus icon — hide vertical line when open */
  #{{ section_id }} .faq__icon-v {
    transition: opacity 0.25s ease, transform 0.25s ease;
    transform-origin: center;
  }
  #{{ section_id }} .faq__item--open .faq__icon-v {
    opacity: 0;
    transform: scaleY(0);
  }

  /* Chevron — rotate when open */
  #{{ section_id }} .faq__item--open .faq__icon {
    transform: rotate(180deg);
  }
  /* But not for plus/x styles */
  #{{ section_id }}.faq--plus .faq__item--open .faq__icon,
  #{{ section_id }}.faq--x .faq__item--open .faq__icon {
    transform: none;
  }

  /* ── ANSWER ── */
  #{{ section_id }} .faq__answer-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.35s ease;
    overflow: hidden;
  }
  #{{ section_id }} .faq__item--open .faq__answer-wrap {
    grid-template-rows: 1fr;
  }
  #{{ section_id }} .faq__answer {
    min-height: 0;
    overflow: hidden;
    padding-bottom: 0;
    transition: padding-bottom 0.35s ease;
  }
  #{{ section_id }} .faq__item--open .faq__answer {
    padding-bottom: var(--faq-answer-pad-bottom);
  }
  #{{ section_id }} .faq__answer,
  #{{ section_id }} .faq__answer p {
    font-family: var(--faq-body-font);
    font-size: var(--faq-a-size);
    line-height: 1.8;
    color: var(--faq-a-color);
    font-weight: 300;
    max-width: var(--faq-answer-max-width);
  }
  #{{ section_id }} .faq__answer p { margin: 0 0 12px; }
  #{{ section_id }} .faq__answer p:last-child { margin-bottom: 0; }
  #{{ section_id }} .faq__answer a {
    color: var(--faq-accent);
    text-decoration: underline;
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 700px) {
    #{{ section_id }}.faq {
      padding: var(--faq-pad-top-mobile) 6vw var(--faq-pad-bottom-mobile);
    }
    #{{ section_id }} .faq__heading {
      font-size: var(--faq-heading-size-mobile);
    }
    #{{ section_id }} .faq__heading-wrap {
      text-align: left;
    }
  }
</style>

<script>
  (function() {
    var section = document.getElementById('{{ section_id }}');
    if (!section) return;

    var items = section.querySelectorAll('.faq__item');

    items.forEach(function(item) {
      var btn = item.querySelector('.faq__question');
      if (!btn) return;

      btn.addEventListener('click', function() {
        var isOpen = item.classList.contains('faq__item--open');

        {% if s.close_others %}
        // Close all other items
        items.forEach(function(other) {
          if (other !== item) {
            other.classList.remove('faq__item--open');
            var otherBtn = other.querySelector('.faq__question');
            if (otherBtn) otherBtn.setAttribute('aria-expanded', 'false');
          }
        });
        {% endif %}

        item.classList.toggle('faq__item--open', !isOpen);
        btn.setAttribute('aria-expanded', String(!isOpen));
      });
    });
  })();
</script>

{% schema %}
{
  "name": "FAQ Accordion",
  "tag": "section",
  "class": "section-faq",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "select",
      "id": "heading_tag",
      "label": "Heading tag (SEO)",
      "options": [
        { "value": "h1", "label": "H1" },
        { "value": "h2", "label": "H2" },
        { "value": "h3", "label": "H3" }
      ],
      "default": "h2"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "Heading",
      "info": "Wrap words in <em> for italic accent.",
      "default": "<p>Frequently asked <em>questions</em></p>"
    },
    {
      "type": "range",
      "id": "heading_gap",
      "label": "Space between heading and first row",
      "min": 12,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },

    {
      "type": "header",
      "content": "Accordion behaviour"
    },
    {
      "type": "checkbox",
      "id": "first_open",
      "label": "Show first item expanded on load",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "close_others",
      "label": "Close other items when one opens",
      "default": false
    },
    {
      "type": "select",
      "id": "icon_style",
      "label": "Toggle icon style",
      "options": [
        { "value": "plus",    "label": "+ / − (plus/minus)" },
        { "value": "x",       "label": "× (times / cross)" },
        { "value": "chevron", "label": "∨ (chevron arrow)" }
      ],
      "default": "x"
    },

    {
      "type": "header",
      "content": "Section spacing"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "label": "Max content width",
      "min": 800,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1440
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side padding",
      "min": 2,
      "max": 12,
      "step": 1,
      "unit": "vw",
      "default": 7
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (desktop)",
      "min": 0,
      "max": 240,
      "step": 4,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding top (mobile)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom (mobile)",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 60
