{%- comment -%}
  ============================================================
  SECTION: Product Story — Theme-Matched, Dark Brand
  ------------------------------------------------------------
  A block-based long-form product narrative that inherits the
  Pillowta design system tokens (dark bg, red accent, Aleo
  display font). Every band is a reorderable block with its own
  background so editors compose the page in the Theme Editor and
  drop in their own photography via image pickers.

  Blocks: header | ingredient | commitments | steps | exclude
          | manufacturing | reviews | rich_text

  Inherits (with fallbacks) from snippets/design-system-variables:
    --color-bg-primary / -secondary / -warm, --color-accent,
    --color-text-primary / -secondary / -muted, --color-border,
    --ft1 (body) --ft2 (display) --ft3 (label/mono)
  ============================================================
{%- endcomment -%}

{%- liquid
  assign s = section.settings
  assign uid = 'pstory-' | append: section.id
-%}

{%- style -%}
  #{{ uid }}{
    /* token bridge — falls back to DS vars, then hard defaults */
    --ps-bg1: var(--color-bg-primary, #0d0d0d);
    --ps-bg2: var(--color-bg-secondary, #1a1a1a);
    --ps-bg3: var(--color-bg-warm, #1c1714);
    --ps-accent: {{ s.accent_color | default: '#e63946' }};
    --ps-gold: {{ s.eyebrow_color | default: '#c29c6b' }};
    --ps-heading: var(--color-text-primary, #ffffff);
    --ps-body: var(--color-text-secondary, #b0b0b0);
    --ps-muted: var(--color-text-muted, #6b6b6b);
    --ps-border: var(--color-border, #333333);
    --ps-display: var(--ft2, var(--font-accent, Georgia, serif));
    --ps-text: var(--ft1, var(--font-body, system-ui, sans-serif));
    --ps-label: var(--ft3, var(--ps-text));
    --ps-maxw: {{ s.container_max_width | default: 1200 }}px;
    --ps-narrow: 760px;
    --ps-side: {{ s.side_padding | default: 5 }}vw;
    --ps-pad-y: {{ s.band_padding | default: 88 }}px;
    --ps-pad-y-m: {{ s.band_padding_mobile | default: 56 }}px;
    --ps-radius: {{ s.corner_radius | default: 6 }}px;
  }

  /* ---- bands ---- */
  #{{ uid }} .ps-band{ padding:var(--ps-pad-y) var(--ps-side); background:var(--ps-bg1); color:var(--ps-body); }
  #{{ uid }} .ps-band--bg2{ background:var(--ps-bg2); }
  #{{ uid }} .ps-band--bg3{ background:var(--ps-bg3); }
  #{{ uid }} .ps-inner{ max-width:var(--ps-maxw); margin:0 auto; }
  #{{ uid }} .ps-inner--narrow{ max-width:var(--ps-narrow); }

  /* ---- shared typography ---- */
  #{{ uid }} .ps-eyebrow{
    font-family:var(--ps-label); font-size:11px; font-weight:500;
    letter-spacing:.22em; text-transform:uppercase; color:var(--ps-gold);
    margin:0 0 14px; display:block;
  }
  #{{ uid }} .ps-title{
    font-family:var(--ps-display); font-weight:600; color:var(--ps-heading);
    font-size:clamp(28px, 4.2vw, 44px); line-height:1.15; letter-spacing:-.01em; margin:0;
  }
  #{{ uid }} .ps-title em{ font-style:italic; color:var(--ps-accent); }
  #{{ uid }} .ps-subtitle{
    font-family:var(--ps-display); font-style:italic; color:var(--ps-body);
    font-size:clamp(16px,2vw,19px); line-height:1.5; margin:12px 0 0;
  }
  #{{ uid }} .ps-divider{ width:48px; height:2px; background:var(--ps-accent); border:0; margin:22px 0 0; }
  #{{ uid }} .ps-center{ text-align:center; }
  #{{ uid }} .ps-center .ps-divider{ margin-left:auto; margin-right:auto; }
  #{{ uid }} .ps-rte p{ color:var(--ps-body); line-height:1.85; margin:0 0 14px; font-family:var(--ps-text); }
  #{{ uid }} .ps-rte p:last-child{ margin-bottom:0; }
  #{{ uid }} .ps-rte em{ font-family:var(--ps-display); font-style:italic; color:var(--ps-accent); }

  /* ---- ingredient row ---- */
  #{{ uid }} .ps-ing{ display:grid; grid-template-columns:1fr 1fr; gap:clamp(28px,5vw,72px); align-items:center; }
  #{{ uid }} .ps-ing--rev .ps-ing__media{ order:2; }
  #{{ uid }} .ps-ing__media{
    position:relative; aspect-ratio:4/5; border-radius:var(--ps-radius); overflow:hidden;
    background:linear-gradient(135deg,#241a14,#0d0d0d); border:1px solid var(--ps-border);
  }
  #{{ uid }} .ps-ing__media img{ width:100%; height:100%; object-fit:cover; display:block; }
  #{{ uid }} .ps-ing__ph{
    position:absolute; inset:auto auto 18px 22px; font-family:var(--ps-display);
    font-style:italic; font-size:54px; color:rgba(255,255,255,.12);
  }
  #{{ uid }} .ps-ing__kicker{ font-family:var(--ps-label); font-size:11px; letter-spacing:.18em; text-transform:uppercase; color:var(--ps-muted); }
  #{{ uid }} .ps-ing__name{ font-family:var(--ps-display); font-weight:600; font-size:clamp(24px,3vw,34px); color:var(--ps-heading); line-height:1.1; margin:8px 0 2px; }
  #{{ uid }} .ps-ing__latin{ font-family:var(--ps-display); font-style:italic; color:var(--ps-gold); font-size:16px; margin-bottom:16px; }
  #{{ uid }} .ps-ing__desc{ line-height:1.85; color:var(--ps-body); font-family:var(--ps-text); }
  #{{ uid }} .ps-ing__badge{
    display:inline-block; margin-top:18px; padding:8px 16px; border:1px solid var(--ps-border);
    border-radius:100px; font-family:var(--ps-label); font-size:11px; letter-spacing:.12em;
    text-transform:uppercase; color:var(--ps-heading); background:rgba(255,255,255,.02);
  }

  /* ---- commitments / steps / exclude grids ---- */
  #{{ uid }} .ps-grid{ display:grid; gap:24px; margin-top:36px; }
  #{{ uid }} .ps-grid--4{ grid-template-columns:repeat(4,1fr); }
  #{{ uid }} .ps-grid--2{ grid-template-columns:repeat(2,1fr); }
  #{{ uid }} .ps-card{ background:rgba(255,255,255,.02); border:1px solid var(--ps-border); border-radius:var(--ps-radius); padding:26px 22px; }
  #{{ uid }} .ps-card__icon{ font-size:26px; line-height:1; margin-bottom:14px; }
  #{{ uid }} .ps-card__title{ font-family:var(--ps-display); font-weight:600; color:var(--ps-heading); font-size:18px; margin:0 0 8px; }
  #{{ uid }} .ps-card__text{ font-size:14px; line-height:1.7; color:var(--ps-body); margin:0; font-family:var(--ps-text); }

  /* commitments split (text + image) */
  #{{ uid }} .ps-split{ display:grid; grid-template-columns:1.3fr 1fr; gap:clamp(28px,5vw,64px); align-items:center; }
  #{{ uid }} .ps-split__img{ aspect-ratio:3/4; border-radius:var(--ps-radius); overflow:hidden; border:1px solid var(--ps-border); background:linear-gradient(135deg,#241a14,#0d0d0d); }
  #{{ uid }} .ps-split__img img{ width:100%; height:100%; object-fit:cover; display:block; }

  /* steps */
  #{{ uid }} .ps-steps{ list-style:none; margin:32px 0 0; padding:0; display:grid; gap:8px; }
  #{{ uid }} .ps-step{ display:grid; grid-template-columns:auto 1fr; gap:22px; padding:22px 0; border-top:1px solid var(--ps-border); }
  #{{ uid }} .ps-step:last-child{ border-bottom:1px solid var(--ps-border); }
  #{{ uid }} .ps-step__num{ font-family:var(--ps-display); font-size:30px; font-weight:600; color:var(--ps-accent); line-height:1; min-width:48px; }
  #{{ uid }} .ps-step__title{ display:block; font-family:var(--ps-display); font-weight:600; color:var(--ps-heading); font-size:18px; margin-bottom:6px; }
  #{{ uid }} .ps-step__text{ color:var(--ps-body); line-height:1.7; font-size:15px; font-family:var(--ps-text); }

  /* exclude grid */
  #{{ uid }} .ps-no{ display:grid; grid-template-columns:repeat(3,1fr); gap:16px; margin-top:36px; }
  #{{ uid }} .ps-no__item{ display:flex; align-items:center; gap:12px; padding:18px 20px; border:1px solid var(--ps-border); border-radius:var(--ps-radius); }
  #{{ uid }} .ps-no__x{ color:var(--ps-accent); font-size:18px; line-height:1; }
  #{{ uid }} .ps-no__label{ font-family:var(--ps-label); font-size:12px; letter-spacing:.08em; text-transform:uppercase; color:var(--ps-heading); }

  /* manufacturing */
  #{{ uid }} .ps-mfg{ display:grid; grid-template-columns:1.1fr 1fr; gap:clamp(28px,5vw,64px); align-items:center; }
  #{{ uid }} .ps-mfg__img{ aspect-ratio:1/1; border-radius:var(--ps-radius); overflow:hidden; border:1px solid var(--ps-border); display:grid; place-items:center; background:linear-gradient(135deg,#241a14,#0d0d0d); }
  #{{ uid }} .ps-mfg__img img{ width:100%; height:100%; object-fit:cover; }
  #{{ uid }} .ps-mfg__img span{ font-family:var(--ps-display); font-style:italic; font-size:120px; color:rgba(255,255,255,.08); }
  #{{ uid }} .ps-partner{ display:flex; align-items:center; gap:14px; margin:24px 0 18px; padding:16px 18px; border:1px solid var(--ps-border); border-radius:var(--ps-radius); background:rgba(255,255,255,.02); }
  #{{ uid }} .ps-partner__k{ font-family:var(--ps-label); font-size:10px; letter-spacing:.2em; text-transform:uppercase; color:var(--ps-muted); }
  #{{ uid }} .ps-partner__n{ font-family:var(--ps-display); font-size:19px; font-weight:500; color:var(--ps-heading); }
  #{{ uid }} .ps-certs{ display:flex; flex-wrap:wrap; gap:10px; }
  #{{ uid }} .ps-cert{ padding:7px 14px; border:1px solid var(--ps-border); border-radius:100px; font-family:var(--ps-label); font-size:11px; letter-spacing:.06em; color:var(--ps-body); }

  /* reviews */
  #{{ uid }} .ps-rev-head{ display:flex; align-items:center; justify-content:center; gap:12px; margin-top:14px; }
  #{{ uid }} .ps-stars{ color:var(--ps-gold); letter-spacing:2px; font-size:18px; }
  #{{ uid }} .ps-rev-meta{ font-size:13px; color:var(--ps-muted); font-family:var(--ps-text); }
  #{{ uid }} .ps-rev-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:20px; margin-top:40px; }
  #{{ uid }} .ps-rev-card{ background:rgba(255,255,255,.02); border:1px solid var(--ps-border); border-radius:var(--ps-radius); padding:26px 24px; }
  #{{ uid }} .ps-rev-card .ps-stars{ font-size:14px; }
  #{{ uid }} .ps-rev-quote{ font-family:var(--ps-display); font-style:italic; font-size:17px; line-height:1.55; color:var(--ps-heading); margin:14px 0 18px; }
  #{{ uid }} .ps-rev-author{ font-family:var(--ps-label); font-size:11px; letter-spacing:.1em; text-transform:uppercase; color:var(--ps-muted); }

  /* ---- responsive ---- */
  @media (max-width:900px){
    #{{ uid }} .ps-grid--4{ grid-template-columns:repeat(2,1fr); }
    #{{ uid }} .ps-rev-grid{ grid-template-columns:repeat(2,1fr); }
  }
  @media (max-width:749px){
    #{{ uid }} .ps-band{ padding:var(--ps-pad-y-m) var(--ps-side); }
    #{{ uid }} .ps-ing,
    #{{ uid }} .ps-split,
    #{{ uid }} .ps-mfg{ grid-template-columns:1fr; gap:24px; }
    #{{ uid }} .ps-ing--rev .ps-ing__media{ order:0; }
    #{{ uid }} .ps-grid--2,
    #{{ uid }} .ps-grid--4,
    #{{ uid }} .ps-no,
    #{{ uid }} .ps-rev-grid{ grid-template-columns:1fr; }
    #{{ uid }} .ps-mfg__img span{ font-size:80px; }
  }
{%- endstyle -%}

<div id="{{ uid }}" class="ps-root">
  {%- for block in section.blocks -%}
    {%- assign b = block.settings -%}
    {%- assign bandbg = b.bg | default: 'bg1' -%}

    {%- case block.type -%}

    {%- when 'header' -%}
      <section class="ps-band ps-band--{{ bandbg }}" {{ block.shopify_attributes }}>
        <div class="ps-inner ps-inner--narrow {% if b.align == 'center' %}ps-center{% endif %}">
          {%- if b.eyebrow != blank -%}<span class="ps-eyebrow">{{ b.eyebrow }}</span>{%- endif -%}
          {%- if b.heading != blank -%}<{{ b.heading_tag | default: 'h2' }} class="ps-title">{{ b.heading }}</{{ b.heading_tag | default: 'h2' }}>{%- endif -%}
          {%- if b.subtitle != blank -%}<p class="ps-subtitle">{{ b.subtitle }}</p>{%- endif -%}
          {%- if b.show_divider -%}<hr class="ps-divider">{%- endif -%}
        </div>
      </section>

    {%- when 'ingredient' -%}
      <section class="ps-band ps-band--{{ bandbg }}" {{ block.shopify_attributes }}>
        <div class="ps-inner ps-ing {% if b.image_side == 'right' %}ps-ing--rev{% endif %}">
          <div class="ps-ing__media">
            {%- if b.image != blank -%}
              <img src="{{ b.image | image_url: width: 900 }}" alt="{{ b.image.alt | default: b.name | escape }}"
                   width="720" height="900" loading="lazy"
                   sizes="(max-width:749px) 90vw, 45vw"
                   srcset="{{ b.image | image_url: width: 480 }} 480w, {{ b.image | image_url: width: 720 }} 720w, {{ b.image | image_url: width: 1080 }} 1080w">
            {%- else -%}
              <span class="ps-ing__ph">{{ b.name | default: 'Ingredient' | truncate: 12, '' }}</span>
            {%- endif -%}
          </div>
          <div class="ps-ing__body">
            {%- if b.kicker != blank -%}<div class="ps-ing__kicker">{{ b.kicker }}</div>{%- endif -%}
            {%- if b.name != blank -%}<h3 class="ps-ing__name">{{ b.name }}</h3>{%- endif -%}
            {%- if b.latin != blank -%}<div class="ps-ing__latin">{{ b.latin }}</div>{%- endif -%}
            {%- if b.description != blank -%}<div class="ps-ing__desc ps-rte">{{ b.description }}</div>{%- endif -%}
            {%- if b.badge != blank -%}<span class="ps-ing__badge">{{ b.badge }}</span>{%- endif -%}
          </div>
        </div>
      </section>

    {%- when 'commitments' -%}
      <section class="ps-band ps-band--{{ bandbg }}" {{ block.shopify_attributes }}>
        <div class="ps-inner ps-split">
          <div>
            {%- if b.eyebrow != blank -%}<span class="ps-eyebrow">{{ b.eyebrow }}</span>{%- endif -%}
            {%- if b.heading != blank -%}<h2 class="ps-title">{{ b.heading }}</h2>{%- endif -%}
            <div class="ps-grid ps-grid--2">
              {%- for i in (1..4) -%}
                {%- assign t = b['title_' | append: i] -%}
                {%- assign d = b['text_' | append: i] -%}
                {%- assign ic = b['icon_' | append: i] -%}
                {%- if t != blank or d != blank -%}
                  <div class="ps-card">
                    {%- if ic != blank -%}<div class="ps-card__icon" aria-hidden="true">{{ ic }}</div>{%- endif -%}
                    {%- if t != blank -%}<h3 class="ps-card__title">{{ t }}</h3>{%- endif -%}
                    {%- if d != blank -%}<p class="ps-card__text">{{ d }}</p>{%- endif -%}
                  </div>
                {%- endif -%}
              {%- endfor -%}
            </div>
          </div>
          {%- if b.image != blank -%}
            <div class="ps-split__img"><img src="{{ b.image | image_url: width: 800 }}" alt="{{ b.image.alt | escape }}" loading="lazy"></div>
          {%- endif -%}
        </div>
      </section>

    {%- when 'steps' -%}
      <section class="ps-band ps-band--{{ bandbg }}" {{ block.shopify_attributes }}>
        <div class="ps-inner ps-split">
          {%- if b.image != blank -%}
            <div class="ps-split__img"><img src="{{ b.image | image_url: width: 800 }}" alt="{{ b.image.alt | escape }}" loading="lazy"></div>
          {%- endif -%}
          <div>
            {%- if b.eyebrow != blank -%}<span class="ps-eyebrow">{{ b.eyebrow }}</span>{%- endif -%}
            {%- if b.heading != blank -%}<h2 class="ps-title">{{ b.heading }}</h2>{%- endif -%}
            <ol class="ps-steps">
              {%- for i in (1..4) -%}
                {%- assign t = b['step_title_' | append: i] -%}
                {%- assign d = b['step_text_' | append: i] -%}
                {%- if t != blank or d != blank -%}
                  <li class="ps-step">
                    <div class="ps-step__num">{{ i | prepend: '0' }}</div>
                    <div>
                      {%- if t != blank -%}<span class="ps-step__title">{{ t }}</span>{%- endif -%}
                      {%- if d != blank -%}<span class="ps-step__text">{{ d }}</span>{%- endif -%}
                    </div>
                  </li>
                {%- endif -%}
              {%- endfor -%}
            </ol>
          </div>
        </div>
      </section>

    {%- when 'exclude' -%}
      <section class="ps-band ps-band--{{ bandbg }}" {{ block.shopify_attributes }}>
        <div class="ps-inner ps-center">
          {%- if b.eyebrow != blank -%}<span class="ps-eyebrow">{{ b.eyebrow }}</span>{%- endif -%}
          {%- if b.heading != blank -%}<h2 class="ps-title">{{ b.heading }}</h2>{%- endif -%}
          {%- if b.subtitle != blank -%}<p class="ps-subtitle">{{ b.subtitle }}</p>{%- endif -%}
          {%- assign items = b.items | newline_to_br | split: '<br />' -%}
          <div class="ps-no">
            {%- for item in items -%}
              {%- assign label = item | strip -%}
              {%- if label != blank -%}
                <div class="ps-no__item"><span class="ps-no__x" aria-hidden="true">&#10005;</span><span class="ps-no__label">{{ label }}</span></div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      </section>

    {%- when 'manufacturing' -%}
      <section class="ps-band ps-band--{{ bandbg }}" {{ block.shopify_attributes }}>
        <div class="ps-inner ps-mfg">
          <div>
            {%- if b.eyebrow != blank -%}<span class="ps-eyebrow">{{ b.eyebrow }}</span>{%- endif -%}
            {%- if b.heading != blank -%}<h2 class="ps-title">{{ b.heading }}</h2>{%- endif -%}
            {%- if b.body != blank -%}<div class="ps-rte" style="margin-top:18px;">{{ b.body }}</div>{%- endif -%}
            {%- if b.partner_name != blank -%}
              <div class="ps-partner">
                {%- if b.partner_icon != blank -%}<span style="font-size:26px;" aria-hidden="true">{{ b.partner_icon }}</span>{%- endif -%}
                <div>
                  {%- if b.partner_label != blank -%}<div class="ps-partner__k">{{ b.partner_label }}</div>{%- endif -%}
                  <div class="ps-partner__n">{{ b.partner_name }}</div>
                </div>
              </div>
            {%- endif -%}
            {%- if b.certs != blank -%}
              {%- assign certs = b.certs | newline_to_br | split: '<br />' -%}
              <div class="ps-certs">
                {%- for c in certs -%}{%- assign cc = c | strip -%}{%- if cc != blank -%}<span class="ps-cert">{{ cc }}</span>{%- endif -%}{%- endfor -%}
              </div>
            {%- endif -%}
          </div>
          <div class="ps-mfg__img">
            {%- if b.image != blank -%}<img src="{{ b.image | image_url: width: 900 }}" alt="{{ b.image.alt | escape }}" loading="lazy">
            {%- else -%}<span aria-hidden="true">{{ b.placeholder_letter | default: 'G' }}</span>{%- endif -%}
          </div>
        </div>
      </section>

    {%- when 'reviews' -%}
      <section class="ps-band ps-band--{{ bandbg }}" {{ block.shopify_attributes }}>
        <div class="ps-inner">
          <div class="ps-center">
            {%- if b.eyebrow != blank -%}<span class="ps-eyebrow">{{ b.eyebrow }}</span>{%- endif -%}
            {%- if b.heading != blank -%}<h2 class="ps-title">{{ b.heading }}</h2>{%- endif -%}
            <div class="ps-rev-head">
              <span class="ps-stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</span>
              <span class="ps-rev-meta">{{ b.rating_value | default: '4.9' }} out of 5 &nbsp;|&nbsp; {{ b.rating_count | default: '128' }} reviews</span>
            </div>
          </div>
          {%- assign rows = b.reviews | newline_to_br | split: '<br />' -%}
          <div class="ps-rev-grid">
            {%- for row in rows -%}
              {%- assign parts = row | strip | split: '|' -%}
              {%- if parts.size > 0 and parts[0] != blank -%}
                <figure class="ps-rev-card">
                  <div class="ps-stars" aria-hidden="true">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
                  <blockquote class="ps-rev-quote">{{ parts[0] | strip }}</blockquote>
                  {%- if parts[1] -%}<figcaption class="ps-rev-author">{{ parts[1] | strip }}{% if parts[2] %} &nbsp;|&nbsp; {{ parts[2] | strip }}{% endif %}</figcaption>{%- endif -%}
                </figure>
              {%- endif -%}
            {%- endfor -%}
          </div>
          {%- if b.app_widget != blank -%}<div class="ps-app-reviews" style="margin-top:40px;">{{ b.app_widget }}</div>{%- endif -%}
        </div>
      </section>

    {%- when 'rich_text' -%}
      <section class="ps-band ps-band--{{ bandbg }}" {{ block.shopify_attributes }}>
        <div class="ps-inner ps-inner--narrow {% if b.align == 'center' %}ps-center{% endif %}">
          {%- if b.eyebrow != blank -%}<span class="ps-eyebrow">{{ b.eyebrow }}</span>{%- endif -%}
          {%- if b.heading != blank -%}<h2 class="ps-title" style="margin-bottom:18px;">{{ b.heading }}</h2>{%- endif -%}
          {%- if b.body != blank -%}<div class="ps-rte">{{ b.body }}</div>{%- endif -%}
        </div>
      </section>

    {%- endcase -%}
  {%- endfor -%}
</div>

{% schema %}
{
  "name": "Product Story",
  "tag": "section",
  "class": "section-product-story",
  "settings": [
    { "type": "header", "content": "Global style" },
    { "type": "paragraph", "content": "Backgrounds, fonts and text colors are inherited from the dark design system. Use the controls below for accents and spacing; each block has its own background selector." },
    { "type": "color", "id": "accent_color", "label": "Accent (CTA / emphasis)", "default": "#e63946" },
    { "type": "color", "id": "eyebrow_color", "label": "Eyebrow / label color", "default": "#c29c6b", "info": "Warm gold by default for a premium editorial feel. Set to your red to stay strictly mono-accent." },
    { "type": "range", "id": "container_max_width", "label": "Max content width", "min": 1000, "max": 1500, "step": 20, "unit": "px", "default": 1200 },
    { "type": "range", "id": "side_padding", "label": "Side padding", "min": 2, "max": 10, "step": 1, "unit": "vw", "default": 5 },
    { "type": "range", "id": "band_padding", "label": "Band padding — desktop", "min": 40, "max": 160, "step": 4, "unit": "px", "default": 88 },
