">\n    <p class=\"cta-note\">Our promise to you isn't just policy — it's the foundation of everything we do.<\/p>\n    <a href=\"https:\/\/pillowta.com\/policies\/privacy-policy\" class=\"cta-btn\">\n      Read our Privacy Promise\n      <svg viewbox=\"0 0 16 16\"><path d=\"M3 8h10M9 4l4 4-4 4\"><\/path><\/svg>\n    <\/a>\n  <\/div>\n\n<\/div>"},"blocks":{}}},"block_order":["ai_gen_block_8e24978_x3MmgK"],"disabled":true,"settings":{}},"blocks_fqzFzU":{"type":"_blocks","blocks":{"ai_gen_block_8e24978_NTLidb":{"type":"ai_gen_block_8e24978","settings":{"desktop_width_percent":100,"background_color":"#ffffff","padding_top":40,"padding_bottom":40,"padding_horizontal":20,"padding_top_mobile":20,"padding_bottom_mobile":20,"padding_horizontal_mobile":15,"custom_code":"<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Section 7 – FAQ<\/title>\n<link href=\"https:\/\/fonts.googleapis.com\/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&amp;family=DM+Sans:wght@300;400;500&amp;display=swap\" rel=\"stylesheet\">\n<style>\n  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n  :root {\n    --cream: #faf7f2;\n    --warm-white: #fff9f4;\n    --charcoal: #1c1c1c;\n    --deep: #2a2320;\n    --muted: #7a7268;\n    --gold: #c9a84c;\n    --gold-light: #e8d5a3;\n    --gold-subtle: rgba(201,168,76,0.12);\n    --sage: #8b9e8a;\n    --divider: rgba(201,168,76,0.18);\n  }\n\n \n\n  .card {\n    max-width: 1250px;\n    width: 100%;\n    background: var(--warm-white);\n    border-radius: 4px;\n    overflow: hidden;\n    box-shadow: 0 12px 80px rgba(0,0,0,0.09), 0 2px 12px rgba(0,0,0,0.04);\n    animation: fadeUp 0.7s ease both;\n  }\n\n  @keyframes fadeUp {\n    from { opacity: 0; transform: translateY(24px); }\n    to { opacity: 1; transform: translateY(0); }\n  }\n\n  \/* ── Header ── *\/\n  .card-header {\n    background: var(--deep);\n    padding: 2.5rem 3rem 2rem;\n    position: relative;\n    overflow: hidden;\n  }\n\n  .card-header::after {\n    content: '?';\n    position: absolute;\n    right: 2rem;\n    top: 50%;\n    transform: translateY(-50%);\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 9rem;\n    font-weight: 700;\n    color: rgba(255,255,255,0.05);\n    line-height: 1;\n    pointer-events: none;\n  }\n\n  .section-label {\n    font-size: 0.62rem;\n    font-weight: 500;\n    letter-spacing: 0.2em;\n    text-transform: uppercase;\n    color: var(--gold);\n    margin-bottom: 0.6rem;\n  }\n\n  .card-header h1 {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: clamp(1.5rem, 4vw, 2.2rem);\n    font-weight: 300;\n    color: #fff;\n    line-height: 1.25;\n  }\n\n  .card-header h1 em {\n    font-style: italic;\n    color: var(--gold-light);\n  }\n\n  .accent-bar {\n    height: 3px;\n    background: linear-gradient(90deg, var(--gold), var(--gold-light), transparent);\n  }\n\n  \/* ── FAQ body ── *\/\n  .faq-body {\n    padding: 2rem 3rem 2.5rem;\n  }\n\n  .faq-intro {\n    font-size: 0.85rem;\n    color: var(--muted);\n    font-weight: 300;\n    font-style: italic;\n    margin-bottom: 1.75rem;\n    padding-bottom: 1.5rem;\n    border-bottom: 1px solid var(--divider);\n  }\n\n  \/* ── Accordion ── *\/\n  .faq-item {\n    border-bottom: 1px solid var(--divider);\n    animation: fadeUp 0.5s ease both;\n  }\n\n  .faq-item:nth-child(1) { animation-delay: 0.05s; }\n  .faq-item:nth-child(2) { animation-delay: 0.1s; }\n  .faq-item:nth-child(3) { animation-delay: 0.15s; }\n  .faq-item:nth-child(4) { animation-delay: 0.2s; }\n  .faq-item:nth-child(5) { animation-delay: 0.25s; }\n\n  .faq-trigger {\n    width: 100%;\n    background: none;\n    border: none;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: space-between;\n    gap: 1.5rem;\n    padding: 1.4rem 0;\n    text-align: left;\n    transition: background 0.2s;\n  }\n\n  .faq-trigger:hover .faq-q {\n    color: var(--gold);\n  }\n\n  .faq-left {\n    display: flex;\n    align-items: center;\n    gap: 1.1rem;\n  }\n\n  .faq-num {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 1.1rem;\n    font-weight: 600;\n    color: var(--gold);\n    min-width: 1.5rem;\n    line-height: 1;\n  }\n\n  .faq-q {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: clamp(1rem, 2.5vw, 1.2rem);\n    font-weight: 600;\n    color: var(--charcoal);\n    line-height: 1.3;\n    transition: color 0.2s;\n  }\n\n  .faq-icon {\n    flex-shrink: 0;\n    width: 2rem;\n    height: 2rem;\n    border-radius: 50%;\n    border: 1px solid var(--divider);\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    transition: background 0.25s, border-color 0.25s, transform 0.35s;\n  }\n\n  .faq-icon svg {\n    width: 0.75rem;\n    height: 0.75rem;\n    stroke: var(--muted);\n    fill: none;\n    stroke-width: 2.5;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n    transition: stroke 0.2s;\n  }\n\n  \/* open state *\/\n  .faq-item.open .faq-icon {\n    background: var(--gold-subtle);\n    border-color: var(--gold);\n    transform: rotate(180deg);\n  }\n\n  .faq-item.open .faq-icon svg {\n    stroke: var(--gold);\n  }\n\n  .faq-item.open .faq-q {\n    color: var(--deep);\n  }\n\n  \/* Panel *\/\n  .faq-panel {\n    display: grid;\n    grid-template-rows: 0fr;\n    transition: grid-template-rows 0.35s ease;\n  }\n\n  .faq-item.open .faq-panel {\n    grid-template-rows: 1fr;\n  }\n\n  .faq-panel-inner {\n    overflow: hidden;\n  }\n\n  .faq-answer {\n    padding: 0 0 1.5rem 2.6rem;\n    font-size: 0.88rem;\n    font-weight: 300;\n    color: #4a4540;\n    line-height: 1.75;\n    max-width: 600px;\n  }\n\n  \/* ── Footer ── *\/\n  .card-footer {\n    border-top: 1px solid var(--divider);\n    padding: 1.4rem 3rem;\n    background: rgba(201,168,76,0.04);\n    display: flex;\n    align-items: center;\n    gap: 0.6rem;\n  }\n\n  .card-footer p {\n    font-size: 0.78rem;\n    color: var(--muted);\n    font-style: italic;\n    font-weight: 300;\n  }\n\n  .card-footer p a {\n    color: var(--charcoal);\n    font-style: normal;\n    font-weight: 500;\n    text-decoration: none;\n    border-bottom: 1px solid var(--gold);\n    padding-bottom: 1px;\n    transition: color 0.2s;\n  }\n\n  .card-footer p a:hover { color: var(--gold); }\n\n  \/* ── Responsive ── *\/\n  @media (max-width: 600px) {\n    .card-header { padding: 2rem 1.5rem 1.5rem; }\n    .faq-body { padding: 1.5rem 1.5rem 2rem; }\n    .card-footer { padding: 1.25rem 1.5rem; }\n    .faq-answer { padding-left: 2.2rem; }\n  }\n<\/style>\n\n\n\n<div class=\"card\">\n\n  <!-- Header -->\n  <div class=\"card-header\">\n    <!-- <div class=\"section-label\">Section 7<\/div> -->\n    <h1>Frequently asked <em>questions<\/em>\n<\/h1>\n  <\/div>\n  <div class=\"accent-bar\"><\/div>\n\n  <!-- FAQ Body -->\n  <div class=\"faq-body\">\n    <p class=\"faq-intro\">Everything you need to know about the Pillowta Tester Circle.<\/p>\n\n    <!-- Item 1 -->\n    <div class=\"faq-item open\">\n      <button class=\"faq-trigger\" aria-expanded=\"true\">\n        <span class=\"faq-left\">\n          <span class=\"faq-num\">01<\/span>\n          <span class=\"faq-q\">What is the Pillowta Tester Circle?<\/span>\n        <\/span>\n        <span class=\"faq-icon\">\n          <svg viewbox=\"0 0 12 12\"><path d=\"M2 4l4 4 4-4\"><\/path><\/svg>\n        <\/span>\n      <\/button>\n      <div class=\"faq-panel\">\n        <div class=\"faq-panel-inner\">\n          <p class=\"faq-answer\">A small, invite-only group exploring gentle sensual self-care — and shaping what Pillowta becomes next.<\/p>\n        <\/div>\n      <\/div>\n    <\/div>\n\n    <!-- Item 2 -->\n    <div class=\"faq-item\">\n      <button class=\"faq-trigger\" aria-expanded=\"false\">\n        <span class=\"faq-left\">\n          <span class=\"faq-num\">02<\/span>\n          <span class=\"faq-q\">Who can apply?<\/span>\n        <\/span>\n        <span class=\"faq-icon\">\n          <svg viewbox=\"0 0 12 12\"><path d=\"M2 4l4 4 4-4\"><\/path><\/svg>\n        <\/span>\n      <\/button>\n      <div class=\"faq-panel\">\n        <div class=\"faq-panel-inner\">\n          <p class=\"faq-answer\">Anyone. All genders and relationship statuses are welcome.<\/p>\n        <\/div>\n      <\/div>\n    <\/div>\n\n    <!-- Item 3 -->\n    <div class=\"faq-item\">\n      <button class=\"faq-trigger\" aria-expanded=\"false\">\n        <span class=\"faq-left\">\n          <span class=\"faq-num\">03<\/span>\n          <span class=\"faq-q\">What will I receive?<\/span>\n        <\/span>\n        <span class=\"faq-icon\">\n          <svg viewbox=\"0 0 12 12\"><path d=\"M2 4l4 4 4-4\"><\/path><\/svg>\n        <\/span>\n      <\/button>\n      <div class=\"faq-panel\">\n        <div class=\"faq-panel-inner\">\n          <p class=\"faq-answer\">Early access to our products before public release, delivered discreetly.<\/p>\n        <\/div>\n      <\/div>\n    <\/div>\n\n    <!-- Item 4 -->\n    <div class=\"faq-item\">\n      <button class=\"faq-trigger\" aria-expanded=\"false\">\n        <span class=\"faq-left\">\n          <span class=\"faq-num\">04<\/span>\n          <span class=\"faq-q\">Is my privacy protected?<\/span>\n        <\/span>\n        <span class=\"faq-icon\">\n          <svg viewbox=\"0 0 12 12\"><path d=\"M2 4l4 4 4-4\"><\/path><\/svg>\n        <\/span>\n      <\/button>\n      <div class=\"faq-panel\">\n        <div class=\"faq-panel-inner\">\n          <p class=\"faq-answer\">Always. Plain packaging. No public tagging. No data sharing.<\/p>\n        <\/div>\n      <\/div>\n    <\/div>\n\n    <!-- Item 5 -->\n    <div class=\"faq-item\">\n      <button class=\"faq-trigger\" aria-expanded=\"false\">\n        <span class=\"faq-left\">\n          <span class=\"faq-num\">05<\/span>\n          <span class=\"faq-q\">What do you expect from testers?<\/span>\n        <\/span>\n        <span class=\"faq-icon\">\n          <svg viewbox=\"0 0 12 12\"><path d=\"M2 4l4 4 4-4\"><\/path><\/svg>\n        <\/span>\n      <\/button>\n      <div class=\"faq-panel\">\n        <div class=\"faq-panel-inner\">\n          <p class=\"faq-answer\">Honest, real feedback — feelings over formality.<\/p>\n        <\/div>\n      <\/div>\n    <\/div>\n\n  <\/div>\n\n  <!-- Footer -->\n  <div class=\"card-footer\">\n    <p>Still have questions? <a href=\"https:\/\/pillowta.com\/pages\/contact\">Get in touch with us →<\/a><\/p>\n  <\/div>\n\n<\/div>\n\n<script>\n  document.querySelectorAll('.faq-trigger').forEach(btn => {\n    btn.addEventListener('click', () => {\n      const item = btn.closest('.faq-item');\n      const isOpen = item.classList.contains('open');\n\n      \/\/ Close all\n      document.querySelectorAll('.faq-item').forEach(i => {\n        i.classList.remove('open');\n        i.querySelector('.faq-trigger').setAttribute('aria-expanded', 'false');\n      });\n\n      \/\/ Toggle clicked\n      if (!isOpen) {\n        item.classList.add('open');\n        btn.setAttribute('aria-expanded', 'true');\n      }\n    });\n  });\n<\/script>"},"blocks":{}}},"block_order":["ai_gen_block_8e24978_NTLidb"],"disabled":true,"settings":{}},"faq_new_created_GkmeF4":{"type":"faq_new_created","blocks":{"faq_item_rTYbT3":{"type":"faq_item","settings":{"question":"What happened with the first 200 co-creators?","answer":"<p>Over 200 people joined, shared their experiences, and gave us feedback that shaped every part of our first product — the formula, the scent, the ritual around it. Now we're doing it again for Product 2.<\/p>"}},"faq_item_hyqDAH":{"type":"faq_item","settings":{"question":"What is the survey about?","answer":"<p>Your intimate life — desires, routines, what's working, what isn't, and what nobody is making yet. It takes under 10 minutes and there are no wrong answers.<\/p>"}},"faq_item_hcfMfH":{"type":"faq_item","settings":{"question":"When do I get the 20% off?","answer":"<p>The discount is sent