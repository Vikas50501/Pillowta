0%);\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 8rem;\n    font-weight: 700;\n    color: rgba(255,255,255,0.05);\n    line-height: 1;\n    pointer-events: none;\n  }\n\n  .section-label {\n    font-family: 'DM Sans', sans-serif;\n    font-size: 0.65rem;\n    font-weight: 500;\n    letter-spacing: 0.18em;\n    text-transform: uppercase;\n    color: var(--gold);\n    margin-bottom: 0.75rem;\n  }\n\n  .card-header h1 {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: clamp(1.6rem, 4vw, 2.4rem);\n    font-weight: 300;\n    color: #fff;\n    line-height: 1.2;\n  }\n\n  .card-header h1 span {\n    font-weight: 600;\n    font-style: italic;\n  }\n\n  \/* Gold accent bar *\/\n  .accent-bar {\n    height: 3px;\n    background: linear-gradient(90deg, var(--gold), var(--gold-light), transparent);\n  }\n\n  \/* Two columns *\/\n  .columns {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 0;\n  }\n\n  .col {\n    padding: 3rem;\n    animation: fadeUp 0.7s ease both;\n  }\n\n  .col:first-child { animation-delay: 0.1s; }\n  .col:last-child {\n    animation-delay: 0.2s;\n    background: rgba(139,158,138,0.06);\n    border-left: 1px solid var(--divider);\n  }\n\n  .col-label {\n    font-size: 0.6rem;\n    font-weight: 500;\n    letter-spacing: 0.2em;\n    text-transform: uppercase;\n    color: var(--muted);\n    margin-bottom: 0.5rem;\n  }\n\n  .col-title {\n    font-family: 'Cormorant Garamond', serif;\n    font-size: 1.5rem;\n    font-weight: 600;\n    margin-bottom: 2rem;\n    position: relative;\n    padding-bottom: 1rem;\n  }\n\n  .col-title::after {\n    content: '';\n    position: absolute;\n    left: 0;\n    bottom: 0;\n    width: 2rem;\n    height: 2px;\n    background: var(--gold);\n  }\n\n  .col:last-child .col-title::after {\n    background: var(--sage);\n  }\n\n  .item-list {\n    list-style: none;\n    display: flex;\n    flex-direction: column;\n    gap: 1.25rem;\n  }\n\n  .item-list li {\n    display: flex;\n    gap: 1rem;\n    align-items: flex-start;\n    font-size: 0.88rem;\n    font-weight: 300;\n    color: #3a3732;\n    line-height: 1.6;\n  }\n\n  .item-list li .icon {\n    flex-shrink: 0;\n    width: 1.5rem;\n    height: 1.5rem;\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin-top: 0.1rem;\n  }\n\n  .col:first-child .item-list li .icon {\n    background: rgba(201,168,76,0.15);\n  }\n\n  .col:last-child .item-list li .icon {\n    background: rgba(139,158,138,0.2);\n  }\n\n  .icon svg {\n    width: 0.8rem;\n    height: 0.8rem;\n  }\n\n  .col:first-child .icon svg { color: var(--gold); }\n  .col:last-child .icon svg { color: var(--sage); }\n\n  \/* Footer note *\/\n  .footer-note {\n    border-top: 1px solid var(--divider);\n    padding: 1.5rem 3rem;\n    display: flex;\n    align-items: center;\n    gap: 0.75rem;\n    background: rgba(201,168,76,0.04);\n  }\n\n  .footer-note p {\n    font-size: 0.75rem;\n    color: var(--muted);\n    font-weight: 300;\n    font-style: italic;\n    line-height: 1.5;\n  }\n\n  .footer-note p strong {\n    font-style: normal;\n    font-weight: 500;\n    color: var(--charcoal);\n  }\n\n  \/* Responsive *\/\n  @media (max-width: 680px) {\n    .card-header { padding: 2rem 1.5rem; }\n    .columns { grid-template-columns: 1fr; }\n    .col { padding: 2rem 1.5rem; }\n    .col:last-child { border-left: none; border-top: 1px solid var(--divider); }\n    .footer-note { padding: 1.25rem 1.5rem; flex-direction: column; align-items: flex-start; }\n  }\n<\/style>\n\n\n\n<div class=\"card\">\n  <div class=\"card-header\">\n    <!-- <div class=\"section-label\">Section 5<\/div> -->\n    <h1>What you <span>receive<\/span> vs what we ask<\/h1>\n  <\/div>\n  <div class=\"accent-bar\"><\/div>\n\n  <div class=\"columns\">\n    <!-- You receive -->\n    <div class=\"col\">\n      <div class=\"col-label\">For you<\/div>\n      <h2 class=\"col-title\">You receive<\/h2>\n      <ul class=\"item-list\">\n