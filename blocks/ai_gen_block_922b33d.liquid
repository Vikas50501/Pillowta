{% doc %}
  @prompt
    create a section where one side image and section side content with button and also keep the button on image and also make it mobile visible and also give the iption of chnage the place of both div, keep the bg black, also give option to keep the content align center, at the image give me a clickable button 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-content-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-image-content-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-image-content-container-{{ ai_gen_id }}.ai-layout-reverse-{{ ai_gen_id }} {
    flex-direction: row-reverse;
  }

  .ai-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    flex: 1;
    min-width: 0;
  }

  .ai-image-clickable-{{ ai_gen_id }} {
    display: block;
    cursor: pointer;
  }

  .ai-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 4 / 3;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-button-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.button_overlay_position_y }}%;
    left: {{ block.settings.button_overlay_position_x }}%;
    transform: translate(-50%, -50%);
    z-index: 2;
  }

  .ai-content-wrapper-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
    text-align: {{ block.settings.content_alignment }};
  }

  .ai-content-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_margin }}px;
    line-height: 1.3;
  }

  .ai-content-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0 0 {{ block.settings.text_margin }}px;
  }

  .ai-content-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    cursor: pointer;
  }

  .ai-content-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover }};
    color: {{ block.settings.button_text_hover }};
    border-color: {{ block.settings.button_border_hover }};
  }

  @media screen and (max-width: 768px) {
    .ai-image-content-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.gap_mobile }}px;
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-image-content-container-{{ ai_gen_id }}.ai-layout-reverse-{{ ai_gen_id }} {
      flex-direction: column;
    }

    {% if block.settings.mobile_image_first %}
      .ai-image-wrapper-{{ ai_gen_id }} {
        order: 1;
      }

      .ai-content-wrapper-{{ ai_gen_id }} {
        order: 2;
      }
    {% else %}
      .ai-content-wrapper-{{ ai_gen_id }} {
        order: 1;
      }

      .ai-image-wrapper-{{ ai_gen_id }} {
        order: 2;
      }
    {% endif %}

    .ai-content-wrapper-{{ ai_gen_id }} {
      text-align: {{ block.settings.content_alignment_mobile }};
    }

    .ai-content-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-content-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-content-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size_mobile }}px;
    }

    {% if block.settings.hide_button_overlay_mobile %}
      .ai-image-button-overlay-{{ ai_gen_id }} {
        display: none;
      }
    {% endif %}
  }
{% endstyle %}

<image-content-section-{{ ai_gen_id }}
  class="ai-image-content-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-image-content-container-{{ ai_gen_id }} {% if block.settings.layout == 'content_image' %}ai-layout-reverse-{{ ai_gen_id }}{% endif %}">
    <div class="ai-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image_link != blank %}
        <a href="{{ block.settings.image_link }}" class="ai-image-clickable-{{ ai_gen_id }}">
          {% if block.settings.image %}
            <img
              src="{{ block.settings.image | image_url: width: 1200 }}"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {% else %}
            <div class="ai-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-image-empty-state-{{ ai_gen_id }}">
                Add an image
              </div>
            </div>
          {% endif %}
        </a>
      {% else %}
        {% if block.settings.image %}
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
        {% else %}
          <div class="ai-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
            <div class="ai-image-empty-state-{{ ai_gen_id }}">
              Add an image
            </div>
          </div>
        {% endif %}
      {% endif %}

      {% if block.settings.show_button_on_image and block.settings.button_text != blank %}
        <div class="ai-image-button-overlay-{{ ai_gen_id }}">
          {% if block.settings.button_link != blank %}
            <a href="{{ block.settings.button_link }}" class="ai-content-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </a>
          {% else %}
            <span class="ai-content-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </span>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="ai-content-wrapper-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-content-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-content-text-{{ ai_gen_id }}">{{ block.settings.text }}</div>
      {% endif %}

      {% if block.settings.show_button_in_content and block.settings.button_text != blank %}
        {% if block.settings.button_link != blank %}
          <a href="{{ block.settings.button_link }}" class="ai-content-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </a>
        {% else %}
          <span class="ai-content-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}
          </span>
        {% endif %}
      {% endif %}
    </div>
  </div>
</image-content-section-{{ ai_gen_id }}>

<script>
  (function() {
    class ImageContentSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('image-content-section-{{ ai_gen_id }}', ImageContentSection{{ ai_gen_id }});
  })();
</script>

