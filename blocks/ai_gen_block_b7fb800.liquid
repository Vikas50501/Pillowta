{% doc %}
  @prompt
    make a section for haeding keep backgound black 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-heading-section-{{ ai_gen_id }} {
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    display: block;
  }

  .ai-heading-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-heading-title-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: {{ block.settings.line_height }};
    margin: 0;
    {% if block.settings.text_transform != 'none' %}
      text-transform: {{ block.settings.text_transform }};
    {% endif %}
  }

  .ai-heading-subtitle-{{ ai_gen_id }} {
    color: {{ block.settings.subtitle_color }};
    font-size: {{ block.settings.subtitle_size }}px;
    margin-top: {{ block.settings.subtitle_spacing }}px;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-heading-section-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    }

    .ai-heading-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-heading-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size_mobile }}px;
    }
  }
{% endstyle %}

<heading-section-{{ ai_gen_id }} class="ai-heading-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-heading-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-heading-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}
    
    {% if block.settings.subtitle != blank %}
      <div class="ai-heading-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</div>
    {% endif %}
  </div>
</heading-section-{{ ai_gen_id }}>

