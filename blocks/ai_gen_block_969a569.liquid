    create a section where one side video and on the video give me the option of write text and secod side give me the option of putting content and blow the content give a button , video is not working when i uplaod it , KEEP THE BACKGROUND black 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-content-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-video-content-container-{{ ai_gen_id }} {
    display: flex;
    gap: 40px;
    align-items: center;
    max-width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-video-content-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    flex: 1;
    min-width: 0;
  }

  .ai-video-content-video-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
  }

  .ai-video-content-video-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-content-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-video-content-video-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-video-content-text-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.overlay_vertical_position }}%;
    left: {{ block.settings.overlay_horizontal_position }}%;
    transform: translate(-50%, -50%);
    z-index: 2;
    text-align: center;
    width: 90%;
    max-width: 500px;
  }

  .ai-video-content-overlay-text-{{ ai_gen_id }} {
    color: {{ block.settings.overlay_text_color }};
    font-size: {{ block.settings.overlay_text_size }}px;
    font-weight: {{ block.settings.overlay_text_weight }};
    margin: 0;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .ai-video-content-content-wrapper-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-video-content-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin: 0 0 16px;
  }

  .ai-video-content-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
    margin: 0 0 24px;
  }

  .ai-video-content-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: {{ block.settings.button_text_weight }};
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-video-content-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-video-content-container-{{ ai_gen_id }} {
      flex-direction: {% if block.settings.mobile_layout == 'video_top' %}column{% else %}column-reverse{% endif %};
      gap: 24px;
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px {{ block.settings.section_padding_horizontal | times: 0.6 }}px {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }

    .ai-video-content-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-video-content-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-video-content-overlay-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.overlay_text_size | times: 0.7 }}px;
    }
  }

  @media screen and (min-width: 750px) {
    .ai-video-content-container-{{ ai_gen_id }} {
      flex-direction: {% if block.settings.layout == 'video_left' %}row{% else %}row-reverse{% endif %};
    }
  }
{% endstyle %}

<video-content-section-{{ ai_gen_id }} class="ai-video-content-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-content-container-{{ ai_gen_id }}">
    <div class="ai-video-content-video-wrapper-{{ ai_gen_id }}">
      <div class="ai-video-content-video-container-{{ ai_gen_id }}">
        {% if block.settings.video != blank %}
          {{
            block.settings.video
            | video_tag:
              class: 'ai-video-content-video-' | append: ai_gen_id,
              autoplay: block.settings.autoplay,
              loop: block.settings.loop,
              muted: block.settings.muted,
              controls: block.settings.show_controls
          }}
        {% elsif block.settings.video_url != blank %}
          <video
            class="ai-video-content-video-{{ ai_gen_id }}"
            {% if block.settings.autoplay %}autoplay{% endif %}
            {% if block.settings.loop %}loop{% endif %}
            {% if block.settings.muted %}muted{% endif %}
            {% if block.settings.show_controls %}controls{% endif %}
            playsinline
          >
            <source src="{{ block.settings.video_url }}" type="video/mp4">
            Your browser does not support the video tag.
          </video>
        {% else %}
          <div class="ai-video-content-video-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if block.settings.overlay_text != blank %}
          <div class="ai-video-content-text-overlay-{{ ai_gen_id }}">
            <h2 class="ai-video-content-overlay-text-{{ ai_gen_id }}">
              {{ block.settings.overlay_text }}
            </h2>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-video-content-content-wrapper-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-video-content-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-video-content-text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank %}
        <a
          href="{{ block.settings.button_link }}"
          class="ai-video-content-button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</video-content-section-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoContentSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.video = this.querySelector('.ai-video-content-video-{{ ai_gen_id }}');
        if (this.video && !this.video.hasAttribute('controls')) {
          this.setupVideoControls();
        }
      }

      setupVideoControls() {
        this.video.addEventListener('click', () => {
          if (this.video.paused) {
            this.video.play();
          } else {
            this.video.pause();
          }
        });
      }
    }

    customElements.define('video-content-section-{{ ai_gen_id }}', VideoContentSection{{ ai_gen_id }});
  })();
</script>

