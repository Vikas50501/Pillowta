{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-content-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-video-content-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
  }

  .ai-video-content-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    {% if block.settings.layout == 'content_left' %}
      flex-direction: row;
    {% else %}
      flex-direction: row-reverse;
    {% endif %}
  }

  .ai-video-content-video-col-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-video-content-content-col-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-video-content-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
    background: #000;
  }

  .ai-video-content-video-{{ ai_gen_id }},
  .ai-video-content-iframe-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: none;
  }

  .ai-video-content-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-video-content-video-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-video-content-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
    width: 80%;
  }

  .ai-video-content-text-{{ ai_gen_id }} {
    padding: 20px 0;
  }

  .ai-video-content-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    line-height: 1.2;
  }

  .ai-video-content-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0 0 {{ block.settings.text_spacing }}px;
  }

  .ai-video-content-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-video-content-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
    border-color: {{ block.settings.button_border_hover_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-video-content-wrapper-{{ ai_gen_id }} {
      flex-direction: column !important;
      gap: 30px;
    }

    .ai-video-content-video-col-{{ ai_gen_id }},
    .ai-video-content-content-col-{{ ai_gen_id }} {
      width: 100%;
      flex: none;
    }

    .ai-video-content-video-wrapper-{{ ai_gen_id }} {
      padding-bottom: 56.25%;
    }

    .ai-video-content-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-video-content-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<video-content-section-{{ ai_gen_id }}
  class="ai-video-content-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-content-container-{{ ai_gen_id }}">
    <div class="ai-video-content-wrapper-{{ ai_gen_id }}">
      <div class="ai-video-content-video-col-{{ ai_gen_id }}">
        <div class="ai-video-content-video-wrapper-{{ ai_gen_id }}">
          {% if block.settings.video_url != blank %}
            {% assign video_url = block.settings.video_url %}
            {% if video_url contains 'youtube.com' or video_url contains 'youtu.be' %}
              {% if video_url contains 'youtu.be' %}
                {% assign video_id = video_url | split: 'youtu.be/' | last | split: '?' | first %}
              {% elsif video_url contains 'watch?v=' %}
                {% assign video_id = video_url | split: 'watch?v=' | last | split: '&' | first %}
              {% else %}
                {% assign video_id = video_url | split: 'embed/' | last | split: '?' | first %}
              {% endif %}
              <iframe
                class="ai-video-content-iframe-{{ ai_gen_id }}"
                src="https://www.youtube.com/embed/{{ video_id }}?autoplay={{ block.settings.autoplay | default: 0 }}&loop={{ block.settings.loop | default: 0 }}&mute={{ block.settings.muted | default: 0 }}&controls={{ block.settings.controls | default: 1 }}&playlist={{ video_id }}"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              ></iframe>
            {% elsif video_url contains 'vimeo.com' %}
              {% assign video_id = video_url | split: 'vimeo.com/' | last | split: '?' | first %}
              <iframe
                class="ai-video-content-iframe-{{ ai_gen_id }}"
                src="https://player.vimeo.com/video/{{ video_id }}?autoplay={{ block.settings.autoplay | default: 0 }}&loop={{ block.settings.loop | default: 0 }}&muted={{ block.settings.muted | default: 0 }}"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
              ></iframe>
            {% else %}
              <video
                class="ai-video-content-video-{{ ai_gen_id }}"
                {% if block.settings.autoplay %}autoplay{% endif %}
                {% if block.settings.loop %}loop{% endif %}
                {% if block.settings.muted %}muted{% endif %}
                {% if block.settings.controls %}controls{% endif %}
                playsinline
                webkit-playsinline
              >
                <source src="{{ video_url }}" type="video/mp4">
                Your browser does not support the video tag.
              </video>
            {% endif %}
          {% elsif block.settings.video %}
            <video
              class="ai-video-content-video-{{ ai_gen_id }}"
              {% if block.settings.autoplay %}autoplay{% endif %}
              {% if block.settings.loop %}loop{% endif %}
              {% if block.settings.muted %}muted{% endif %}
              {% if block.settings.controls %}controls{% endif %}
              playsinline
              webkit-playsinline
            >
              <source
                src="{{ block.settings.video }}"
                type="video/mp4"
              >
              Your browser does not support the video tag.
            </video>
          {% else %}
            <div class="ai-video-content-video-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
              <div class="ai-video-content-empty-state-{{ ai_gen_id }}">
                Add a video or video URL
              </div>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-video-content-content-col-{{ ai_gen_id }}">
        <div class="ai-video-content-text-{{ ai_gen_id }}">
          {% if block.settings.heading != blank %}
            <h2 class="ai-video-content-heading-{{ ai_gen_id }}">
              {{ block.settings.heading }}
            </h2>
          {% endif %}

          {% if block.settings.description != blank %}
            <div class="ai-video-content-description-{{ ai_gen_id }}">
              {{ block.settings.description }}
            </div>
          {% endif %}

          {% if block.settings.button_text != blank and block.settings.button_link != blank %}
            <a
              href="{{ block.settings.button_link }}"
              class="ai-video-content-button-{{ ai_gen_id }}"
            >
              {{ block.settings.button_text }}
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</video-content-section-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoContentSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const video = this.querySelector('.ai-video-content-video-{{ ai_gen_id }}');
        if (video) {
          this.setupVideo(video);
          if (!video.hasAttribute('controls')) {
            this.setupVideoObserver(video);
          }
        }
      }

      setupVideo(video) {
        video.setAttribute('playsinline', '');
        video.setAttribute('webkit-playsinline', '');
        
        video.addEventListener('loadedmetadata', function() {
          if (video.hasAttribute('autoplay') && video.hasAttribute('muted')) {
            video.play().catch(function(error) {
              console.log('Autoplay prevented:', error);
            });
          }
        });
      }

      setupVideoObserver(video) {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.5
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              video.play().catch(() => {});
            } else {
              video.pause();
            }
          });
        }, options);

        observer.observe(video);
      }
    }

    customElements.define('video-content-section-{{ ai_gen_id }}', VideoContentSection{{ ai_gen_id }});
  })();
</script>

