{% doc %}
  @prompt
    create a liquid code section , keep the bg color black 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-liquid-code-{{ ai_gen_id }} {
    width: 100%;
    display: block;
  }

  .ai-liquid-code__container-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    margin: 0 auto;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-liquid-code__content-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-liquid-code__container-{{ ai_gen_id }} {
      width: 100%;
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-liquid-code-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-liquid-code__container-{{ ai_gen_id }}">
    <div class="ai-liquid-code__content-{{ ai_gen_id }}">
      {{ block.settings.liquid_code }}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Liquid code",
  "settings": [
    {
      "type": "header",
      "content": "Code"
    },
    {
      "type": "liquid",
      "id": "liquid_code",
      "label": "Liquid code",
      "default": "<p>Add your custom Liquid code here</p>"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Top padding (mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Bottom padding (mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "label": "Horizontal padding (mobile)",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Liquid code"
    }
  ],
  "tag": null
}
{% endschema %}