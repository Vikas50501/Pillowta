{% doc %}
  @prompt
    create a section where i add my own html css design , make a section where i add one side content in content give me 1 heading and 2 paragraphs, one learn more button and in other part, keep the image. The size of image should be equal to size of content, keept  the bg black, keep the heading color white and aslo image side bg color black and give me option of change fornt family of text
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% liquid
  if block.settings.heading_font == 'ft1'
    if settings.fonts == '1'
      assign heading_font_family = settings.font1.family | append: ', ' | append: settings.font1.fallback_families
    else
      assign heading_font_family = settings.gfont1
    endif
  elsif block.settings.heading_font == 'ft2'
    if settings.fonts == '1'
      assign heading_font_family = settings.font2.family | append: ', ' | append: settings.font2.fallback_families
    else
      assign heading_font_family = settings.gfont2
    endif
  else
    if settings.fonts == '1'
      assign heading_font_family = settings.font3.family | append: ', ' | append: settings.font3.fallback_families
    else
      assign heading_font_family = settings.gfont3
    endif
  endif

  if block.settings.text_font == 'ft1'
    if settings.fonts == '1'
      assign text_font_family = settings.font1.family | append: ', ' | append: settings.font1.fallback_families
    else
      assign text_font_family = settings.gfont1
    endif
  elsif block.settings.text_font == 'ft2'
    if settings.fonts == '1'
      assign text_font_family = settings.font2.family | append: ', ' | append: settings.font2.fallback_families
    else
      assign text_font_family = settings.gfont2
    endif
  else
    if settings.fonts == '1'
      assign text_font_family = settings.font3.family | append: ', ' | append: settings.font3.fallback_families
    else
      assign text_font_family = settings.gfont3
    endif
  endif
%}

{% style %}
  .ai-content-image-block-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-content-image-container-{{ ai_gen_id }} {
    display: flex;
    align-items: stretch;
    gap: {{ block.settings.gap }}px;
    max-width: 100%;
  }

  .ai-content-image-container-{{ ai_gen_id }}.reverse {
    flex-direction: row-reverse;
  }

  .ai-content-side-{{ ai_gen_id }},
  .ai-image-side-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-content-side-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: {{ block.settings.content_padding }}px;
    background-color: {{ block.settings.content_bg_color }};
  }

  .ai-content-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    font-family: {{ heading_font_family }};
    margin: 0 0 {{ block.settings.heading_margin }}px 0;
    line-height: 1.3;
  }

  .ai-content-paragraph-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    font-family: {{ text_font_family }};
    line-height: 1.6;
    margin: 0 0 {{ block.settings.paragraph_spacing }}px 0;
  }

  .ai-content-paragraph-{{ ai_gen_id }}:last-of-type {
    margin-bottom: {{ block.settings.button_margin_top }}px;
  }

  .ai-learn-more-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    text-align: center;
  }

  .ai-learn-more-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover_color }};
    color: {{ block.settings.button_text_hover_color }};
    border-color: {{ block.settings.button_border_hover_color }};
  }

  .ai-image-side-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background-color: {{ block.settings.image_bg_color }};
  }

  .ai-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: block;
  }

  .ai-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.image_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #999;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 768px) {
    .ai-content-image-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 0;
    }

    .ai-content-image-container-{{ ai_gen_id }}.reverse {
      flex-direction: column;
    }

    .ai-content-side-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_mobile }}px;
    }

    .ai-content-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-content-paragraph-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-image-side-{{ ai_gen_id }} {
      min-height: 300px;
    }
  }
{% endstyle %}

<div class="ai-content-image-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-content-image-container-{{ ai_gen_id }} {% if block.settings.layout == 'image_left' %}reverse{% endif %}">
    <div class="ai-content-side-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-content-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.paragraph_1 != blank %}
        <div class="ai-content-paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph_1 }}</div>
      {% endif %}

      {% if block.settings.paragraph_2 != blank %}
        <div class="ai-content-paragraph-{{ ai_gen_id }}">{{ block.settings.paragraph_2 }}</div>
      {% endif %}

      {% if block.settings.button_text != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-learn-more-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>

    <div class="ai-image-side-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <div class="ai-image-wrapper-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.image | image_url: width: 1200 }}"
            alt="{{ block.settings.image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.image.width }}"
            height="{{ block.settings.image.height }}"
          >
        </div>
      {% else %}
        <div class="ai-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-empty-state-{{ ai_gen_id }}">
            Add an image
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

