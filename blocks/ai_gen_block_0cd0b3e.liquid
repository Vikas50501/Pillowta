{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-content-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: #000000;
    padding: 60px 0;
  }

  .ai-video-content-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-video-content-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
  }

  .ai-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.video_border_radius }}px;
  }

  .ai-video-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background-color: #1a1a1a;
  }

  .ai-video-element-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #1a1a1a;
  }

  .ai-video-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .ai-video-text-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    text-align: center;
    z-index: 2;
    width: 90%;
    pointer-events: none;
  }

  .ai-video-overlay-text-{{ ai_gen_id }} {
    color: {{ block.settings.overlay_text_color }};
    font-size: {{ block.settings.overlay_text_size }}px;
    font-weight: {{ block.settings.overlay_text_weight }};
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.7);
    margin: 0;
  }

  .ai-content-wrapper-{{ ai_gen_id }} {
    color: {{ block.settings.content_text_color }};
    text-align: {{ block.settings.content_alignment }};
  }

  .ai-content-heading-{{ ai_gen_id }} {
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin: 0 0 20px 0;
    line-height: 1.3;
  }

  .ai-content-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.content_size }}px;
    line-height: 1.6;
    margin-bottom: 30px;
  }

  .ai-content-text-{{ ai_gen_id }} p {
    margin: 0 0 15px 0;
  }

  .ai-content-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-content-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 15px 35px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: {{ block.settings.button_text_weight }};
    transition: all 0.3s ease;
    border: 2px solid {{ block.settings.button_border_color }};
  }

  .ai-content-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg }};
    color: {{ block.settings.button_hover_text }};
    border-color: {{ block.settings.button_hover_border }};
  }

  @media screen and (max-width: 768px) {
    .ai-video-content-section-{{ ai_gen_id }} {
      padding: 40px 0;
    }

    .ai-video-content-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    {% if block.settings.mobile_video_first %}
      .ai-video-wrapper-{{ ai_gen_id }} {
        order: 1;
      }

      .ai-content-wrapper-{{ ai_gen_id }} {
        order: 2;
      }
    {% endif %}

    .ai-content-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-video-overlay-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.overlay_text_size | times: 0.7 }}px;
    }

    .ai-content-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.content_size | times: 0.9 }}px;
    }

    .ai-content-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_text_size | times: 0.9 }}px;
      padding: 12px 28px;
    }
  }
{% endstyle %}

<video-content-section-{{ ai_gen_id }} class="ai-video-content-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-content-container-{{ ai_gen_id }}">
    <div class="ai-video-content-grid-{{ ai_gen_id }}">
      <div class="ai-video-wrapper-{{ ai_gen_id }}">
        <div class="ai-video-container-{{ ai_gen_id }}">
          {% if block.settings.video != blank %}
            {% assign video_sources = block.settings.video.sources %}
            <video
              class="ai-video-element-{{ ai_gen_id }}"
              {% if block.settings.autoplay %}autoplay{% endif %}
              {% if block.settings.loop %}loop{% endif %}
              {% if block.settings.muted %}muted{% endif %}
              playsinline
              preload="auto"
              webkit-playsinline
            >
              {% for source in video_sources %}
                <source src="{{ source.url }}" type="{{ source.mime_type }}">
              {% endfor %}
              Your browser does not support the video tag.
            </video>
          {% else %}
            <div class="ai-video-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}

          {% if block.settings.video_overlay_text != blank %}
            <div class="ai-video-text-overlay-{{ ai_gen_id }}">
              <h2 class="ai-video-overlay-text-{{ ai_gen_id }}">{{ block.settings.video_overlay_text }}</h2>
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-content-wrapper-{{ ai_gen_id }}">
        {% if block.settings.heading != blank %}
          <h2 class="ai-content-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
        {% endif %}

        {% if block.settings.content != blank %}
          <div class="ai-content-text-{{ ai_gen_id }}">
            {{ block.settings.content }}
          </div>
        {% endif %}

        {% if block.settings.button_text != blank and block.settings.button_link != blank %}
          {% comment %} <a href="{{ block.settings.button_link }}" class="ai-content-button-{{ ai_gen_id }}"> {% endcomment %}
          <a href="{{ block.settings.button_link }}" class="btn btn-md btn1">

            {{ block.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</video-content-section-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoContentSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.video = this.querySelector('.ai-video-element-{{ ai_gen_id }}');
        if (this.video) {
          this.setupVideo();
        }
      }

      setupVideo() {
        this.video.load();
        
        this.video.addEventListener('canplay', () => {
          if (this.video.autoplay) {
            this.video.play().catch((error) => {
              console.log('Video autoplay prevented:', error);
            });
          }
        });

        this.video.addEventListener('loadeddata', () => {
          if (this.video.autoplay) {
            this.video.play().catch((error) => {
              console.log('Video autoplay prevented:', error);
            });
          }
        });

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              this.video.play().catch((error) => {
                console.log('Video play prevented:', error);
              });
            } else {
              if (!this.video.paused) {
                this.video.pause();
              }
            }
          });
        }, { threshold: 0.25 });

        observer.observe(this.video);
      }
    }

    customElements.define('video-content-section-{{ ai_gen_id }}', VideoContentSection{{ ai_gen_id }});
  })();
</script>

