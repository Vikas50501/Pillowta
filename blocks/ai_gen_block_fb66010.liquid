            </div>

            <div class="ai-form-field-{{ ai_gen_id }}">
              <label class="ai-form-label-{{ ai_gen_id }}" for="contact-message-{{ ai_gen_id }}">
                {{ block.settings.field4_label }}
              </label>
              <textarea
                id="contact-message-{{ ai_gen_id }}"
                name="contact[body]"
                class="ai-form-textarea-{{ ai_gen_id }}"
                placeholder="{{ block.settings.field4_placeholder }}"
                required
              ></textarea>
            </div>

            <div class="ai-form-field-{{ ai_gen_id }}">
              <label class="ai-form-label-{{ ai_gen_id }}">
                {{ block.settings.field5_label }}
              </label>
              <div class="ai-radio-group-{{ ai_gen_id }}">
                <div class="ai-radio-option-{{ ai_gen_id }}">
                  <input
                    type="radio"
                    id="feedback-yes-{{ ai_gen_id }}"
                    name="contact[feedback_type]"
                    value="Yes"
                    required
                  >
                  <label for="feedback-yes-{{ ai_gen_id }}">{{ block.settings.option1_text }}</label>
                </div>
                <div class="ai-radio-option-{{ ai_gen_id }}">
                  <input
                    type="radio"
                    id="feedback-anonymous-{{ ai_gen_id }}"
                    name="contact[feedback_type]"
                    value="Yes, anonymously"
                  >
                  <label for="feedback-anonymous-{{ ai_gen_id }}">{{ block.settings.option2_text }}</label>
                </div>
                <div class="ai-radio-option-{{ ai_gen_id }}">
                  <input
                    type="radio"
                    id="feedback-review-{{ ai_gen_id }}"
                    name="contact[feedback_type]"
                    value="Yes, with a short review"
                  >
                  <label for="feedback-review-{{ ai_gen_id }}">{{ block.settings.option3_text }}</label>
                </div>
                <div class="ai-radio-option-{{ ai_gen_id }}">
                  <input
                    type="radio"
                    id="feedback-video-{{ ai_gen_id }}"
                    name="contact[feedback_type]"
                    value="Yes, with audio/video feedback"
                  >
                  <label for="feedback-video-{{ ai_gen_id }}">{{ block.settings.option4_text }}</label>
                </div>
              </div>
            </div>

            <button type="submit" class="ai-form-button-{{ ai_gen_id }}">
              {{ block.settings.button_text }}
            </button>

            {% if form.posted_successfully? %}
              <div id="ai-form-success-{{ ai_gen_id }}" class="ai-form-success-{{ ai_gen_id }}">
                {{ block.settings.success_message }}
              </div>
            {% endif %}
          </div>
        {%- endform -%}
      </div>

      <div class="ai-image-box-{{ ai_gen_id }}">
        {% if block.settings.image %}
          <div class="ai-image-wrapper-{{ ai_gen_id }}">
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="{{ block.settings.image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          </div>
        {% else %}
          <div class="ai-image-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    {% else %}
      <div class="ai-image-box-{{ ai_gen_id }}">
