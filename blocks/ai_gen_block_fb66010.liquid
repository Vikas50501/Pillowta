              <label class="ai-form-label-{{ ai_gen_id }}" for="contact-name-{{ ai_gen_id }}">
                {{ block.settings.field1_label }}
              </label>
              <input
                type="text"
                id="contact-name-{{ ai_gen_id }}"
                name="contact[name]"
                class="ai-form-input-{{ ai_gen_id }}"
                placeholder="{{ block.settings.field1_placeholder }}"
                required
              >
            </div>

            <div class="ai-form-field-{{ ai_gen_id }}">
              <label class="ai-form-label-{{ ai_gen_id }}" for="contact-email-{{ ai_gen_id }}">
                {{ block.settings.field2_label }}
              </label>
              <input
                type="email"
                id="contact-email-{{ ai_gen_id }}"
                name="contact[email]"
                class="ai-form-input-{{ ai_gen_id }}"
                placeholder="{{ block.settings.field2_placeholder }}"
                autocomplete="email"
                {% if form.errors %}
                  aria-invalid="true"
                  aria-describedby="ai-form-error-email-{{ ai_gen_id }}"
                {% endif %}
                {% if form.posted_successfully? %}
                  aria-describedby="ai-form-success-{{ ai_gen_id }}"
                {% endif %}
                required
              >
              {% if form.errors %}
                <div id="ai-form-error-email-{{ ai_gen_id }}" class="ai-form-error-{{ ai_gen_id }}">
                  {{ form.errors.messages.email }}
                </div>
              {% endif %}
            </div>

            <div class="ai-form-field-{{ ai_gen_id }}">
              <label class="ai-form-label-{{ ai_gen_id }}" for="contact-location-{{ ai_gen_id }}">
                {{ block.settings.field3_label }}
              </label>
              <input
                type="text"
                id="contact-location-{{ ai_gen_id }}"
                name="contact[location]"
                class="ai-form-input-{{ ai_gen_id }}"
                placeholder="{{ block.settings.field3_placeholder }}"
                required
