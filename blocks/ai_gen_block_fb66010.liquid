{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-form-image-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-form-image-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 50% 50%;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    gap: 0;
    min-height: {{ block.settings.min_height }}px;
  }

  .ai-form-box-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 60px 40px;
    background-color: {{ block.settings.form_bg_color }};
  }

  .ai-form-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: 500px;
  }

  .ai-form-heading-{{ ai_gen_id }} {
    color: {{ block.settings.form_text_color }};
    font-size: {{ block.settings.heading_size }}px;
    margin: 0 0 10px 0;
    text-align: {{ block.settings.text_align }};
  }

  .ai-form-subheading-{{ ai_gen_id }} {
    color: {{ block.settings.form_text_color }};
    font-size: {{ block.settings.subheading_size }}px;
    margin: 0 0 30px 0;
    opacity: 0.8;
    text-align: {{ block.settings.text_align }};
  }

  .ai-form-field-{{ ai_gen_id }} {
    margin-bottom: 20px;
  }

  .ai-form-label-{{ ai_gen_id }} {
    display: block;
    color: {{ block.settings.form_text_color }};
    font-size: 14px;
    margin-bottom: 8px;
  }

  .ai-form-input-{{ ai_gen_id }},
  .ai-form-textarea-{{ ai_gen_id }} {
    width: 100%;
    padding: 12px 16px;
    border: 1px solid {{ block.settings.input_border_color }};
    border-radius: {{ block.settings.input_border_radius }}px;
    background-color: {{ block.settings.input_bg_color }};
    color: {{ block.settings.form_text_color }};
    font-size: 14px;
  }

  .ai-form-textarea-{{ ai_gen_id }} {
    min-height: 100px;
    resize: vertical;
  }

  .ai-form-input-{{ ai_gen_id }}::placeholder,
  .ai-form-textarea-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.form_text_color }};
    opacity: 0.5;
  }

  .ai-radio-group-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-radio-option-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    cursor: pointer;
  }

  .ai-radio-option-{{ ai_gen_id }} input[type="radio"] {
    width: 18px;
    height: 18px;
    cursor: pointer;
    accent-color: {{ block.settings.button_color }};
  }

  .ai-radio-option-{{ ai_gen_id }} label {
    color: {{ block.settings.form_text_color }};
    font-size: 14px;
    cursor: pointer;
    margin: 0;
  }

  .ai-form-button-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 24px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-form-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-image-box-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    background-color: {{ block.settings.image_bg_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.image_padding }}px;
  }

  .ai-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.image_max_width }}px;
    height: auto;
  }

  .ai-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    object-fit: contain;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    max-width: {{ block.settings.image_max_width }}px;
    aspect-ratio: 3 / 4;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    max-width: 150px;
    max-height: 200px;
  }

  .ai-form-success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    margin-top: 15px;
    text-align: center;
  }

  .ai-form-error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    margin-top: 8px;
    font-size: 13px;
  }

  @media screen and (max-width: 768px) {
    .ai-form-image-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
    }

    .ai-form-box-{{ ai_gen_id }} {
      padding: 30px 20px;
    }

    .ai-image-box-{{ ai_gen_id }} {
      min-height: 400px;
      padding: {{ block.settings.image_padding | times: 0.6 }}px;
    }

    .ai-form-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-form-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_size | times: 0.9 }}px;
    }

    .ai-image-wrapper-{{ ai_gen_id }} {
      max-width: {{ block.settings.image_max_width | times: 0.8 }}px;
    }
  }
{% endstyle %}

<form-image-section-{{ ai_gen_id }}
