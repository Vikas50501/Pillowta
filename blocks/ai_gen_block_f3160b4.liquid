{% doc %}
  @prompt
    create a section of heading and keep bg color black, give me the option of top spacing and button spacing
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-heading-block-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
    background-color: {{ block.settings.background_color }};
    margin-top: {{ block.settings.top_spacing }}px;
  }

  .ai-heading-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-heading-title-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.bottom_spacing }}px 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: {{ block.settings.line_height }};
    {% if block.settings.text_transform != 'none' %}
      text-transform: {{ block.settings.text_transform }};
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-heading-block-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px {{ block.settings.padding_horizontal_mobile }}px;
      margin-top: {{ block.settings.top_spacing_mobile }}px;
    }

    .ai-heading-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
      margin-bottom: {{ block.settings.bottom_spacing_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-heading-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-heading-container-{{ ai_gen_id }}">
    {% if block.settings.heading_tag == 'h1' %}
      <h1 class="ai-heading-title-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h1>
    {% elsif block.settings.heading_tag == 'h2' %}
      <h2 class="ai-heading-title-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h2>
    {% elsif block.settings.heading_tag == 'h3' %}
      <h3 class="ai-heading-title-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h3>
    {% elsif block.settings.heading_tag == 'h4' %}
      <h4 class="ai-heading-title-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h4>
    {% elsif block.settings.heading_tag == 'h5' %}
      <h5 class="ai-heading-title-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h5>
    {% elsif block.settings.heading_tag == 'h6' %}
      <h6 class="ai-heading-title-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h6>
    {% else %}
      <p class="ai-heading-title-{{ ai_gen_id }}">{{ block.settings.heading_text }}</p>
    {% endif %}
  </div>
</div>

