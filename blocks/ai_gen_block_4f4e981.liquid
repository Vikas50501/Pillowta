{% doc %}
  @prompt
    make a section where i add one side video and second side content like headling and paragraphy and give the heading for both div and keep the main heading in center , kepp the bg balck , remove the main heading , and also  give the option of change the both keep visa versa 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-content-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-video-content-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-video-content-wrapper-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    align-items: center;
    {% if block.settings.layout == 'content_video' %}
      flex-direction: row-reverse;
    {% endif %}
  }

  .ai-video-content-video-side-{{ ai_gen_id }},
  .ai-video-content-content-side-{{ ai_gen_id }} {
    flex: 1;
  }

  .ai-video-content-side-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.side_heading_margin }}px;
  }

  .ai-video-content-side-heading-{{ ai_gen_id }} h3 {
    font-size: {{ block.settings.side_heading_size }}px;
    color: {{ block.settings.side_heading_color }};
    margin: 0;
    font-weight: {{ block.settings.side_heading_weight }};
  }

  .ai-video-content-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
    background-color: #f4f4f4;
  }

  .ai-video-content-video-wrapper-{{ ai_gen_id }} iframe,
  .ai-video-content-video-wrapper-{{ ai_gen_id }} video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-video-content-video-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-video-content-video-placeholder-{{ ai_gen_id }} svg {
    width: 100px;
    height: 100px;
    opacity: 0.3;
  }

  .ai-video-content-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.text_line_height }};
    color: {{ block.settings.text_color }};
  }

  .ai-video-content-text-{{ ai_gen_id }} p {
    margin: 0 0 15px;
  }

  .ai-video-content-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 768px) {
    .ai-video-content-wrapper-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-video-content-side-heading-{{ ai_gen_id }} h3 {
      font-size: {{ block.settings.side_heading_size | times: 0.8 }}px;
    }

    .ai-video-content-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-video-content-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.6 }}px 0 {{ block.settings.section_padding_bottom | times: 0.6 }}px;
    }
  }
{% endstyle %}

<div class="ai-video-content-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-content-container-{{ ai_gen_id }}">
    <div class="ai-video-content-wrapper-{{ ai_gen_id }}">
      <div class="ai-video-content-video-side-{{ ai_gen_id }}">
        {% if block.settings.video_heading != blank %}
          <div class="ai-video-content-side-heading-{{ ai_gen_id }}">
            <h3>{{ block.settings.video_heading }}</h3>
          </div>
        {% endif %}

        <div class="ai-video-content-video-wrapper-{{ ai_gen_id }}">
          {% if block.settings.video_url != blank %}
            {% if block.settings.video_url contains 'youtube.com' or block.settings.video_url contains 'youtu.be' %}
              {% assign video_id = block.settings.video_url | split: 'v=' | last | split: '/' | last | split: '&' | first %}
              <iframe
                src="https://www.youtube.com/embed/{{ video_id }}"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            {% elsif block.settings.video_url contains 'vimeo.com' %}
              {% assign video_id = block.settings.video_url | split: '/' | last %}
              <iframe
                src="https://player.vimeo.com/video/{{ video_id }}"
                allow="autoplay; fullscreen; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            {% else %}
              <video controls>
                <source src="{{ block.settings.video_url }}" type="video/mp4">
                Your browser does not support the video tag.
              </video>
            {% endif %}
          {% else %}
            <div class="ai-video-content-video-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      </div>

      <div class="ai-video-content-content-side-{{ ai_gen_id }}">
        {% if block.settings.content_heading != blank %}
          <div class="ai-video-content-side-heading-{{ ai_gen_id }}">
            <h3>{{ block.settings.content_heading }}</h3>
          </div>
        {% endif %}

        {% if block.settings.content_text != blank %}
          <div class="ai-video-content-text-{{ ai_gen_id }}">
            {{ block.settings.content_text }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Video and content",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout order",
      "options": [
        { "value": "video_content", "label": "Video | Content" },
        { "value": "content_video", "label": "Content | Video" }
      ],
      "default": "video_content"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between sides",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 60
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Video side"
    },
    {
      "type": "text",
      "id": "video_heading",
      "label": "Video heading",
      "default": "Watch Our Journey"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video URL"
    },
    {
      "type": "range",
      "id": "video_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Content side"
    },
    {
      "type": "text",
      "id": "content_heading",
      "label": "Content heading",
      "default": "About Us"
    },
    {
      "type": "richtext",
      "id": "content_text",
      "label": "Content text",
      "default": "<p>We are passionate about creating amazing products that make a difference. Our journey started with a simple idea and has grown into something truly special.</p><p>Join us as we continue to innovate and bring you the best experience possible.</p>"
    },
    {
      "type": "header",
      "content": "Side headings style"
    },
    {
      "type": "range",
      "id": "side_heading_size",
      "label": "Font size",
      "min": 14,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "side_heading_color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "select",
      "id": "side_heading_weight",
      "label": "Font weight",
      "options": [
        { "value": "300", "label": "Light" },
        { "value": "400", "label": "Regular" },
        { "value": "500", "label": "Medium" },
        { "value": "600", "label": "Semi Bold" },
        { "value": "700", "label": "Bold" }
      ],
      "default": "600"
    },
    {
      "type": "range",
      "id": "side_heading_margin",
      "label": "Margin bottom",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Text style"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "text_line_height",
      "label": "Line height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "default": 1.6
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Video and content"
    }
  ]
}
{% endschema %}
