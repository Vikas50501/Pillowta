{% doc %}
  @prompt
    create a section where 3 card in each card give me the option to put paragraph, keep the bg color black, redesgin the section now give me 3 card where i add images and on the images i add some text and keep the bg colur black
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-cards-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: #000000;
  }

  .ai-image-cards__container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-image-cards__card-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.card_border_radius }}px;
    transition: transform 0.3s ease;
  }

  .ai-image-cards__card-{{ ai_gen_id }}:hover {
    transform: translateY(-5px);
  }

  .ai-image-cards__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
  }

  .ai-image-cards__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-cards__placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #1a1a1a;
  }

  .ai-image-cards__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-cards__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    transition: opacity 0.3s ease;
  }

  .ai-image-cards__card-{{ ai_gen_id }}:hover .ai-image-cards__overlay-{{ ai_gen_id }} {
    opacity: {{ block.settings.overlay_hover_opacity }};
  }

  .ai-image-cards__content-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: {{ block.settings.content_vertical_align }};
    align-items: {{ block.settings.content_horizontal_align }};
    padding: {{ block.settings.content_padding }}px;
    z-index: 2;
    text-align: {{ block.settings.text_align }};
  }

  .ai-image-cards__title-{{ ai_gen_id }} {
    color: {{ block.settings.title_color }};
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    margin: 0 0 {{ block.settings.title_margin }}px 0;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .ai-image-cards__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.text_line_height }};
    margin: 0;
    text-shadow: 0 1px 3px rgba(0, 0, 0, 0.3);
  }

  .ai-image-cards__text-{{ ai_gen_id }} p {
    margin: 0 0 10px 0;
  }

  .ai-image-cards__text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-image-cards__container-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-image-cards__container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_gap | times: 0.7 }}px;
    }

    .ai-image-cards__content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding | times: 0.7 }}px;
    }

    .ai-image-cards__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.85 }}px;
    }

    .ai-image-cards__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-image-cards-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-cards__container-{{ ai_gen_id }}">
    <div class="ai-image-cards__card-{{ ai_gen_id }}">
      <div class="ai-image-cards__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.card_1_image %}
          <img
            src="{{ block.settings.card_1_image | image_url: width: 800 }}"
            alt="{{ block.settings.card_1_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.card_1_image.width }}"
            height="{{ block.settings.card_1_image.height }}"
            class="ai-image-cards__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-image-cards__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
        <div class="ai-image-cards__overlay-{{ ai_gen_id }}"></div>
      </div>
      <div class="ai-image-cards__content-{{ ai_gen_id }}">
        {% if block.settings.card_1_title != blank %}
          <h3 class="ai-image-cards__title-{{ ai_gen_id }}">{{ block.settings.card_1_title }}</h3>
        {% endif %}
        {% if block.settings.card_1_text != blank %}
          <div class="ai-image-cards__text-{{ ai_gen_id }}">
            {{ block.settings.card_1_text }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-image-cards__card-{{ ai_gen_id }}">
      <div class="ai-image-cards__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.card_2_image %}
          <img
            src="{{ block.settings.card_2_image | image_url: width: 800 }}"
            alt="{{ block.settings.card_2_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.card_2_image.width }}"
            height="{{ block.settings.card_2_image.height }}"
            class="ai-image-cards__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-image-cards__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
        <div class="ai-image-cards__overlay-{{ ai_gen_id }}"></div>
      </div>
      <div class="ai-image-cards__content-{{ ai_gen_id }}">
        {% if block.settings.card_2_title != blank %}
          <h3 class="ai-image-cards__title-{{ ai_gen_id }}">{{ block.settings.card_2_title }}</h3>
        {% endif %}
        {% if block.settings.card_2_text != blank %}
          <div class="ai-image-cards__text-{{ ai_gen_id }}">
            {{ block.settings.card_2_text }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-image-cards__card-{{ ai_gen_id }}">
      <div class="ai-image-cards__image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.card_3_image %}
          <img
            src="{{ block.settings.card_3_image | image_url: width: 800 }}"
            alt="{{ block.settings.card_3_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.card_3_image.width }}"
            height="{{ block.settings.card_3_image.height }}"
            class="ai-image-cards__image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-image-cards__placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
        <div class="ai-image-cards__overlay-{{ ai_gen_id }}"></div>
      </div>
      <div class="ai-image-cards__content-{{ ai_gen_id }}">
        {% if block.settings.card_3_title != blank %}
          <h3 class="ai-image-cards__title-{{ ai_gen_id }}">{{ block.settings.card_3_title }}</h3>
        {% endif %}
        {% if block.settings.card_3_text != blank %}
          <div class="ai-image-cards__text-{{ ai_gen_id }}">
            {{ block.settings.card_3_text }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

