{% doc %}
  @prompt
    create a section where one side image and second side the content part , keep the bg colur black and keep the image portrait 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-image-content-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-image-content-container-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.gap }}px;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  {% if block.settings.layout == 'image_right' %}
    .ai-image-content-container-{{ ai_gen_id }} {
      flex-direction: row-reverse;
    }
  {% endif %}

  .ai-image-content-image-wrapper-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.image_width }}%;
    max-width: {{ block.settings.image_width }}%;
  }

  .ai-image-content-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-image-content-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_aspect_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: {{ block.settings.image_border_radius }}px;
    position: relative;
  }

  .ai-image-content-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-image-content-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-image-content-content-wrapper-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
  }

  .ai-image-content-heading-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.heading_margin }}px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    line-height: 1.3;
  }

  .ai-image-content-text-{{ ai_gen_id }} {
    margin: 0 0 {{ block.settings.text_margin }}px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.6;
  }

  .ai-image-content-text-{{ ai_gen_id }} p {
    margin: 0 0 15px;
  }

  .ai-image-content-text-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  .ai-image-content-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    transition: all 0.3s ease;
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
  }

  .ai-image-content-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_bg_hover }};
    color: {{ block.settings.button_text_hover }};
    border-color: {{ block.settings.button_border_hover }};
  }

  @media screen and (max-width: 749px) {
    .ai-image-content-container-{{ ai_gen_id }} {
      flex-direction: column;
      gap: {{ block.settings.gap_mobile }}px;
      padding: {{ block.settings.padding_top_mobile }}px {{ block.settings.padding_horizontal_mobile }}px {{ block.settings.padding_bottom_mobile }}px;
    }

    {% if block.settings.layout == 'image_right' %}
      .ai-image-content-container-{{ ai_gen_id }} {
        flex-direction: column;
      }
    {% endif %}

    .ai-image-content-image-wrapper-{{ ai_gen_id }} {
      flex: 0 0 100%;
      max-width: 100%;
    }

    .ai-image-content-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size_mobile }}px;
    }

    .ai-image-content-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }

    .ai-image-content-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-image-content-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-image-content-container-{{ ai_gen_id }}">
    <div class="ai-image-content-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-image-content-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-image-content-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-image-content-empty-state-{{ ai_gen_id }}">
            Add an image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-image-content-content-wrapper-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-image-content-heading-{{ ai_gen_id }}">
          {{ block.settings.heading }}
        </h2>
      {% endif %}

      {% if block.settings.text != blank %}
        <div class="ai-image-content-text-{{ ai_gen_id }}">
          {{ block.settings.text }}
        </div>
      {% endif %}

      {% if block.settings.button_text != blank and block.settings.button_link != blank %}
        <a
          href="{{ block.settings.button_link }}"
          {% comment %} class="ai-image-content-button-{{ ai_gen_id }}" {% endcomment %}
          class="btn btn-md btn1"
        >
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

